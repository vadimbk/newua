{{ header }}<style type="text/css">
.error{
    color: red;
}
</style>
{{ column_left }} 
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-cod" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
        <a href="{{ cloner }}" data-toggle="tooltip" title="{{ button_cloner }}" class="btn btn-default">{{ entry_cloner }}</a>
        <a href="{{ log }}" data-toggle="tooltip" title="{{ heading_title_logs }}" class="btn btn-default">{{ button_logs }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %} 
        <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
        {% endfor %} 
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if (error_warning) %} 
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }} 
      <button type="button" class="close" data-dismiss="alert">&times;</button> 
    </div>
    {% endif %} 
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i></h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-cod" class="form-horizontal">
        <table class="table">
        <thead>
           <h4>{{ text_allset }}</h4>
        </thead>
        <tr>
        <td width="25%"><span class="required">*</span> {{ entry_license }}</td>
        <td><input type="text" name="{{ pname }}_license" value="{{ artpr_license }}" />
          <br />
          {% if (error_license) %} 
          <span class="error">{{ error_license }}</span>
          {% endif %}</td>
        </tr>
        <tr>
        <td width="25%"><span class="required">*</span> {{ entry_login }}</td>
        <td><input type="text" name="{{ pname }}_login" value="{{ artpr_login }}" />
          <br />
          {% if (error_login) %} 
          <span class="error">{{ error_login }}</span>
          {% endif %}</td>
        </tr>
        <tr>
        <td><span class="required">*</span> {{ entry_password }}</td>
        <td><input name="{{ pname }}_password" value="{{ artpr_password }}" />
          <br />
          {% if (error_password) %} 
          <span class="error">{{ error_password }}</span>
          {% endif %}</td>
        </tr>
        <tr>
          <td><span class="required">*</span> {{ entry_result_url }}</td>
          <td>{{ copy_result_url }}</td>
        </tr>
        <tr>
          {% set pole = 'currency_merch' %} 
          <td>{{ _context['entry_' ~ pole] }}</td>
          <td>
            <select name="{{ pname }}_{{ pole }}">
            {% for ar in manypoles[pole] %} 
            {% if _context['artpr_' ~ pole] == ar %} 
            <option value="{{ ar }}" selected="selected"/>{{ ar }}</option>
             {% else %} 
              <option value="{{ ar }}" />{{ ar }}</option>
            {% endif %} 
            {% endfor %} 
            </select>
          </td>
        </tr>  
        <tr>
          <td>{{ entry_currency_shop }}</td>
          <td><select name="{{ pname }}_currency_shop">
                    {% for currency in currencies %} 
                    {% if (currency['code'] == artpr_currency_shop) %} 
                    <option value="{{ currency['code'] }}" selected="selected">{{ currency['title'] }}</option>
                    {% else %} 
                    <option value="{{ currency['code'] }}">{{ currency['title'] }}</option>
                    {% endif %} 
                    {% endfor %} 
              </select>
          </td>
        </tr>
        {% if (twostage_show == constant('true')) %} 
        <tr>
          <td width="25%">{{ entry_twostage }}</td>
          <td>{% if (artpr_twostage) %} 
            <input type="radio" name="{{ pname }}_twostage" value="1" checked="checked" />
            {{ text_twostage }} 
            <input type="radio" name="{{ pname }}_twostage" value="0" />
