<script>
  $(document).ready(function() {
    $('#pay_tab').click(function () {
      $('#create').prop("checked", true);
      $('.hideotlog').hide('fast');
      $('.showotlog').show('fast');
    });
    $('#stock_tab').click(function () {
      $('#create').prop("checked", true);
      $('.hideotlog').hide('fast');
      $('.showotlog').show('fast');
    });
    $('#standard_tab').click(function () {
      $('.hideotlog').show('fast');
      $('.showotlog').hide('fast');
    });


    $('#artpr_currency_pay_all').click(function(){
      var checked = $(this).is (':checked');
      $('.checkboxc').prop('checked', checked);
    });

    $('.checkboxc').on('change', function(){
        $('#artpr_currency_pay_all').prop('checked', $('.checkboxc').length == $('.checkboxc:checked').length);
    });

    
    $('#artpr_gruppa_all').click(function(){
      var checked = $(this).is (':checked');
      $('.checkboxg').prop('checked', checked);
    });

    $('.checkboxg').on('change', function(){
        $('#artpr_gruppa_all').prop('checked', $('.checkboxg').length == $('.checkboxg:checked').length);
    });



    $('#artpr_shippings_all').click(function(){
      var checked = $(this).is (':checked');
      $('.checkbox_ship').prop('checked', checked);
    });

    $('.checkbox_ship').on('change', function(){
        $('#artpr_shippings_all').prop('checked', $('.checkbox_ship').length == $('.checkbox_ship:checked').length);
    });

});

function toggleParentCheckedCur(status) {
     if(status==false)
     $("#artpr_currency_pay_all").attr("checked",status); 
     else
     {
        var isallchecked = true;
        $(".checkboxc").each(function() {
        if(!$(this).attr("checked"))
           isallchecked = false;
     })
     if(isallchecked)
        $("#artpr_currency_pay_all").attr("checked", true);
     } 
}

function toggleParentChecked(status) {
     if(status==false)
     $("#artpr_gruppa_all").attr("checked",status); 
     else
     {
        var isallchecked = true;
        $(".checkboxg").each(function() {
        if(!$(this).attr("checked"))
           isallchecked = false;
     })
     if(isallchecked)
        $("#artpr_gruppa_all").attr("checked", true);
     } 
}

function toggleParentCheckedShip(status) {
     if(status==false)
     $("#artpr_shippings_all").attr("checked",status); 
     else
     {
        var isallchecked_ship = true;
        $(".checkbox_ship").each(function() {
        if(!$(this).attr("checked"))
           isallchecked_ship = false;
     })
     if(isallchecked_ship)
        $("#artpr_shippings_all").attr("checked", true); 
     } 
}
</script>
