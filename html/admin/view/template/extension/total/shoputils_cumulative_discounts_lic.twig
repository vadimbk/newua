{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        {% if not error %}
          <button type="submit" form="form-shoputils-lic" class="btn btn-primary"><i class="fa fa-save"></i> {{ button_save }}</button>
        {% endif %}
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a>
      </div>
      <h1><img src="{{ icon }}"> {{ heading_title }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-shoputils-lic" class="form-horizontal">
          <div class="form-group">
            <div class="col-sm-12">
                <table class="form">
                    <tr>
                        <td colspan="2">
                            <a href="https://opencart.market" target="_blank"><img src="https://opencart.market/image/data/logo/logo-for-modules.png" alt="https://opencart.market" /></a>
                            {% if error %}
                                <br /><br />{{ entry_key }}
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        {% if not error %}
                            <td>
                                <textarea rows="13" cols="50" name="lic_data"></textarea>
                            </td>
                        {% endif %}
                        <td style="vertical-align:top; padding-left:10px;"{{ error ? ' colspan="2"' : ''}}>
                            {% if not error %}
                                {{ text_get_key }}<br /><br />
                                {{ text_domain }}<br /><br />
                            {% endif %}
                            {% if loader %}
                                {{ text_loader }}
                                {% if not loader_compare %}
                                    {{ text_error }}<br />{{ error_loader_version }}
                                {% else %}
                                    {{ text_ok }}
                                {% endif %}
                            {% else %}
                                {{ error_loader }}
                            {% endif %}
                            <br /><br />{{ text_php }}
                            {% if not php_compare %}
                                {{ text_error }}<br />{{ error_php_version }}
                            {% else %}
                                {{ text_ok }}
                            {% endif %}
                        </td>
                    </tr>
                </table>
            </div><!-- </div class="col-sm-12">  -->
          </div><!-- </div class="form-group"> -->
        </form>
      </div><!-- </div class="panel-body"> -->
    </div><!-- </div class="panel panel-default"> -->
  </div><!-- </div class="container-fluid"> -->
</div><!-- </div id="content"> -->
{{ footer }}