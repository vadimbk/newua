{{ header }}{{ column_left }}
<div id="content">
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-account" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">Close</button>
      </div>
    {% endif %}
    {% if success %}  
      <div class="alert alert-success"><i class="fa fa-info-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">Close</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <ul class="nav nav-tabs">
          <li class="active"><a href="#tab-module" data-toggle="tab">Данные</a></li>
          <li><a href="#tab-license" data-toggle="tab">Настройки модуля</a></li>
        </ul>   
        <div class="tab-content">
            <div class="tab-pane active" id="tab-module">
            <div class="container-fluid">
              <form action = "{{ period }}" method="post" enctype="multipart/form-data" id= "filter_form">
                <div class="col-sm-6">
                  <div class="form-group">
                    <label class="control-label" for="input-date-added">{{ start_date_text }}</label>
                    <div class="input-group date">
                      <input type="text" onkeypress="return false;" value="{{ date_start }}" name="date_start" placeholder="{{ start_date_text }}" data-date-format="YYYY-MM-DD" id="input-date-added" class="form-control" />
                      <span class="input-group-btn">
                      <button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button>
                      </span>
                    </div>
                  </div>
                </div>
                <div class="col-sm-6">
                        <div class="form-group">
                          <label class="control-label" for="input-date-added">{{ end_date_text }}</label>
                          <div class="input-group date">
                            <input type="text" onkeypress="return false;" value="{{ date_end }}" name="date_end" placeholder="{{ end_date_text }}" data-date-format="YYYY-MM-DD" id="input-date-added" class="form-control" />
                            <span class="input-group-btn">
                            <button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button>
                            </span>
                          </div>
                        </div>
                </div>
                <div class="col-sm-6">
                  <div class="form-group">
                    <label class="control-label" for="input-status">{{ entry_parametr }}</label>
                    <select name="filter_parametr" id="filter_parametr" class="form-control">
                    {% for parametr in text_filter_parametr %}
                      {% if parametr == filter_parametr %}
                        <option value="{{ parametr }}" selected="selected">{{ parametr }}</option>
                      {% else %}
                        <option value="{{ parametr }}">{{ parametr }}</option>
                      {% endif %}
                    {% endfor %}
                    </select>
                  </div>
                </div>
                <div class="col-sm-6">
                  <button type="button" onclick="resetForm()" id="clear-filter" class="btn btn-primary pull-right"> {{ button_clear }}</button>
                    <button style="margin-right:10px;" type="submit" id="button-filter" class="btn btn-primary pull-right"><i class="fa fa-search"></i>Filter</button>
                </div>
              </form>
            </div> 
                    <div class="well" style="margin: 20px;">
                        
                          <div class="col-lg-10 col-md-10 col-sm-10 col-xs-10" >
                              <h3 style="text-align:center;">Таблица эффективности каналов ({{ date_start }} - {{ date_end }})</h3>
                          </div>
                            <input type="hidden" name="date_start" value="{{ date_start }}" placeholder="" data-date-format="YYYY-MM-DD" id="input-date-start" class="form-control" />
                            <input type="hidden" name="date_end" value="{{ date_end }}" placeholder="" data-date-format="YYYY-MM-DD" id="input-date-end" class="form-control" />
                        
                        <div class="row">
                            <table class="table table-bordered table-hover">
                                    <thead>
                                        <tr>
                                            <td class="text-center">Источник заказа</td>
                                            <td class="text-center">Кол-во заказов</td> 
                                            <td class="text-center">Выручка</td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        
                                        {% if chanel_order_list %}
                                            {% for order in chanel_order_list %}
                                                <tr>
                                                  <td class="text-center">   
                                                  {% if order.referer %}
                                                    {{ order.referer }}
                                                  {% elseif order.utm_source %}
                                                    {{ order.utm_source }}
                                                  {% elseif order.utm_medium %}
                                                    {{ order.utm_medium }}
                                                  {% elseif order.utm_campaign %}
                                                    {{ order.utm_campaign }}
                                                  {% elseif order.utm_content %}
                                                    {{ order.utm_content }}
                                                  {% elseif order.utm_term %}
                                                    {{ order.utm_term }}
                                                  {% endif %}                                                  
                                                  </td>
                                                  <td class="text-center">{{ order.quantity }}</td>
                                                  <td class="text-center">{{ order.total }}</td>
                                                </tr>
                                            {% endfor %}
                                        {% endif %}
                                    </tbody>
                            </table>
                        </div>
                    </div> 

                    
                    
                    <div id="piechart0" style="width:100%; min-height:500px; display: inline-block;"></div>
                    
                        <script type="text/javascript">
                          google.charts.load('current', {'packages':['corechart']});
                          google.charts.setOnLoadCallback(drawChart);

                          function drawChart() {

                            var data = google.visualization.arrayToDataTable([
                              ['Канал', 'Кол-во заказов'],
                              
                              {% for order in chanel_order_list %}
                                  {% if order.referer %}
                                    ['{{ order.referer }}',{{ order.quantity }}],
                                  {% elseif order.utm_source %}                
                                    ['{{ order.utm_source }}',{{ order.quantity }}],
                                  {% elseif order.utm_medium %}
                                    ['{{ order.utm_medium }}',{{ order.quantity }}],
                                  {% elseif order.utm_campaign %}
                                    ['{{ order.utm_campaign }}',{{ order.quantity }}],
                                  {% elseif order.utm_content %}
                                    ['{{ order.utm_content }}',{{ order.quantity }}],
                                  {% elseif order.utm_term %}
                                    ['{{ order.utm_term }}',{{ order.quantity }}],
                                  {% endif %}  
                              {% endfor %}
                              
                            ]);

                            var options = {
                              title: 'Каналы привлечения заказов(кол-во заказов)'
                            };

                            var chart = new google.visualization.PieChart(document.getElementById('piechart0'));

                            chart.draw(data, options);
                          }
                        </script>
                      

                      <div id="piechart1" style="width:100%; min-height:500px; display: inline-block;"></div>
                      
                        <script type="text/javascript">
                          google.charts.load('current', {'packages':['corechart']});
                          google.charts.setOnLoadCallback(drawChart);

                          function drawChart() {

                            var data = google.visualization.arrayToDataTable([
                              ['Канал', 'Кол-во заказов'],
                              {% for order in chanel_order_list %}
                                  {% if order.referer %}
                                    ['{{ order.referer }}',{{ order.total }}],
                                  {% elseif order.utm_source %}                
                                    ['{{ order.utm_source }}',{{ order.total }}],
                                  {% elseif order.utm_medium %}
                                    ['{{ order.utm_medium }}',{{ order.total }}],
                                  {% elseif order.utm_campaign %}
                                    ['{{ order.utm_campaign }}',{{ order.total }}],
                                  {% elseif order.utm_content %}
                                    ['{{ order.utm_content }}',{{ order.total }}],
                                  {% elseif order.utm_term %}
                                    ['{{ order.utm_term }}',{{ order.total }}],
                                  {% endif %}  
                              {% endfor %}
                            ]);

                            var options = {
                              title: 'Каналы привлечения заказов(выручка)'
                            };

                            var chart = new google.visualization.PieChart(document.getElementById('piechart1'));

                            chart.draw(data, options);
                          }

                        </script>
                    
                    
                    {% for referer in order_referer_chanel %}

                      <hr>
                      <div id="chart_div{{ loop.index0 }}" style="width: 100%; height: 500px;"></div>
                      <div id="chart_div{{ loop.index0 }}{{ loop.index0 }}" style="width: 100%; height: 500px;"></div>
                      <hr>
                     
                        <script type="text/javascript">
                          google.charts.load('current', {'packages':['corechart']});
                          google.charts.setOnLoadCallback(drawChart);

                          function drawChart() {
                            var data = google.visualization.arrayToDataTable([

                              ['Дата', 'кол-во заказов'],
                              {% for chanel in referer %}
                                ['{{ chanel.date }}',{{ chanel.quantity }}],
                              {% endfor %}
                              ]);

                            var options = {
                              title: '{{ referer.0.name }} - кол-во заказов',
                              hAxis: {title: 'Дата',  titleTextStyle: {color: '#333'}},
                              vAxis: {minValue: 0},

                            };

                            var chart = new google.visualization.AreaChart(document.getElementById('chart_div{{ loop.index0 }}'));
                            chart.draw(data, options);
                          }
                        </script>
                        <script type="text/javascript">
                          google.charts.load('current', {'packages':['corechart']});
                          google.charts.setOnLoadCallback(drawChart);

                          function drawChart() {
                            var data = google.visualization.arrayToDataTable([
                              ['Дата', 'Выручка'],

                              {% for chanel in referer %}
                                ['{{ chanel.date }}',{{ chanel.total }}],
                              {% endfor %}

                              ]);

                            var options = {
                              title: '{{ referer.0.name }} - выручка',
                              hAxis: {title: 'Дата',  titleTextStyle: {color: '#333'}},
                              vAxis: {minValue: 0}
                            };

                            var chart = new google.visualization.AreaChart(document.getElementById('chart_div{{ loop.index0 }}{{ loop.index0 }}'));
                            chart.draw(data, options);
                          }
                        </script>
                        
                    
                    {% endfor %}
                    
            </div>
            <div class="tab-pane" id="tab-license">
              <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-account" class="form-horizontal">
                <div class="form-group">
                  <div class="col-sm-12" style="margin-bottom: 10px;">
                    <div class="col-sm-4">
                        <label class="control-label" for="order_source_key">Изменить лицензию</label>
                    </div>
                    <div class="col-sm-4">
                        <input type="password" id="order_source_key" name="order_source_key" value="{{ order_source_key }}" style="display: -webkit-inline-box; margin-right: 10px;height: 30px;" class="form-control">
                    </div>
                  </div>
                  <div class="col-sm-12">
                    <div class="col-sm-4">
                      <label class="control-label" for="input-status">{{ entry_status }}</label>
                    </div>
                    <div class="col-sm-4">
                      <select name="order_source_status" id="input-status" class="form-control">
                        {% if order_source_status == 1 %}
                        	<option value="1" selected="selected">{{ text_enabled }}</option>
                        	<option value="0">{{ text_disabled }}</option>
                        {% else %}
                        	<option value="1">{{ text_enabled }}</option>
                        	<option value="0" selected="selected">{{ text_disabled }}</option>
                        {% endif %}
                      </select>
                    </div>
                  </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_referer }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_referer" id="input-model" class="form-control">
                            {% if order_source_referer %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_utm_source }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_utm_source" id="input-model" class="form-control">
                            {% if order_source_utm_source %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_utm_medium }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_utm_medium" id="input-model" class="form-control">
                            {% if order_source_utm_medium %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_utm_campaign }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_utm_campaign" id="input-model" class="form-control">
                            {% if order_source_utm_campaign %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_utm_content }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_utm_content" id="input-model" class="form-control">
                            {% if order_source_utm_content %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-2 control-label" for="input-model">{{ entry_utm_term }}</label>
                    <div class="col-sm-4">
                          <select name="order_source_utm_term" id="input-model" class="form-control">
                            {% if order_source_utm_term %}
                            	<option value="1" selected="selected">{{ text_enabled }}</option>
                            	<option value="0">{{ text_disabled }}</option>
                            {% else %}
                            	<option value="1">{{ text_enabled }}</option>
                            	<option value="0" selected="selected">{{ text_disabled }}</option>
                            {% endif %}
                          </select>
                    </div>
                </div>


              </form>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% block javascripts %}
  <script src="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.js" type="text/javascript"></script>
  <link href="view/javascript/jquery/datetimepicker/bootstrap-datetimepicker.min.css" type="text/css" rel="stylesheet" media="screen" />
	<script type="text/javascript"><!--
		$('.date').datetimepicker({
			language: '{{ datepicker }}',
			pickTime: false
		});

		function resetForm()
		{
		  $('[name=date_start]').val('');
		  $('[name=date_end]').val('');
		}
		//--></script>
		<script type="text/javascript"><!--
		  $(document).keypress(function (e) {
		      if (e.which == 13) {
		              document.getElementById("button-filter").click();
		      }
		  });
	//--></script>
{% endblock %}
{{ footer }} 