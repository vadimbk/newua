{{ header }} 

<link rel="stylesheet" type="text/css" href="view/javascript/bootstrap-colorpicker/dist/css/bootstrap-colorpicker.min.css" />
<script type="text/javascript" src="view/javascript/bootstrap-colorpicker/dist/js/bootstrap-colorpicker.js"></script>

{{ column_left }} 

<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %} 
        <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
        {% endfor %} 
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if (error_warning) %} 
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }} 
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %} 
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form" class="form-horizontal">
        
          <ul class="nav nav-tabs" id="language">
            {% for language in languages %} 
            <li><a href="#language{{ language['language_id'] }}" data-toggle="tab"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language['name'] }}" /> {{ language['name'] }}</a></li>
            {% endfor %} 
          </ul>
          <div class="tab-content">
            {% for language in languages %} 
            <div class="tab-pane" id="language{{ language['language_id'] }}">
              <table class="table table-striped table-bordered table-hover">
                
                <tr>
                  <td>{{ status_display }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][display]" class="form-control" >
                      <option value="product_category" {{ status_description[language['language_id']]['display'] is defined and status_description[language['language_id']]['display'] == 'product_category' ? 'selected="selected"' : '' }}>{{ status_display_product_category }}</option>
                      <option value="product" {{ status_description[language['language_id']]['display'] is defined and status_description[language['language_id']]['display'] == 'product' ? 'selected="selected"' : '' }}>{{ status_display_product }}</option>
                      <option value="category" {{ status_description[language['language_id']]['display'] is defined and status_description[language['language_id']]['display'] == 'category' ? 'selected="selected"' : '' }}>{{ status_display_category }}</option>
                      <option value="disabled" {{ status_description[language['language_id']]['display'] is defined and status_description[language['language_id']]['display'] == 'disabled' ? 'selected="selected"' : '' }}>{{ status_display_disabled }}</option>
                    </select>  

                  </td>
                </tr>
                
                <tr>
                  <td width="20%">{{ status_image }}</td>
                  <td valign="top">
                    <a href="" id="thumb-image{{ language['language_id'] }}" data-toggle="image" class="img-thumbnail"><img src="{{ thumb[language['language_id']] }}" alt="" title="" data-placeholder="{{ placeholder }}" /></a>
                    <input type="hidden" name="status_description[{{ language['language_id'] }}][image]" value="{{ status_description[language['language_id']]['image'] is defined ? status_description[language['language_id']]['image'] : '' }}" id="image{{ language['language_id'] }}"  />
                    <input type="hidden" name="status_description[{{ language['language_id'] }}][name_attribute_id]" value="" />
                    
                    {% if (error_image[language['language_id']] is defined) %} 
                      <div class="text-danger">{{ error_image[language['language_id']] }}</div>
                    {% endif %}  
                  </td>
                </tr>

                <tr>
                  <td class="required">{{ status_name }}</td>
                  <td><input type="text" name="status_description[{{ language['language_id'] }}][name]" size="100" value="{{ status_description[language['language_id']]['name'] is defined ? status_description[language['language_id']]['name'] : '' }}" class="form-control" />
                  
                    {% if (error_name[language['language_id']] is defined) %} 
                      <div class="text-danger">{{ error_name[language['language_id']] }}</div>
                    {% endif %} 
                  </td>
                </tr>
								
                <tr>
                  <td>{{ status_url }}</td>
                  <td><input type="text" name="status_description[{{ language['language_id'] }}][url]" size="100" value="{{ status_description[language['language_id']]['url'] is defined ? status_description[language['language_id']]['url'] : '' }}" class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_sticker }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][sticker]" class="form-control" >
                      <option value="" {{ status_description[language['language_id']]['sticker'] is not defined or status_description[language['language_id']]['sticker'] == '' ? 'selected="selected"' : '' }}>{{ sticker_disable }}</option>
                      <option value="left-top" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'left-top' ? 'selected="selected"' : '' }}>{{ sticker_left_top }}</option>
                      <option value="left-center" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'left-center' ? 'selected="selected"' : '' }}>{{ sticker_left_center }}</option>
                      <option value="left-bottom" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'left-bottom' ? 'selected="selected"' : '' }}>{{ sticker_left_bottom }}</option>
                      <option value="right-top" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'right-top' ? 'selected="selected"' : '' }}>{{ sticker_right_top }}</option>
                      <option value="right-center" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'right-center' ? 'selected="selected"' : '' }}>{{ sticker_right_center }}</option>
                      <option value="right-bottom" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'right-bottom' ? 'selected="selected"' : '' }}>{{ sticker_right_bottom }}</option>
                      <option value="center-top" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'center-top' ? 'selected="selected"' : '' }}>{{ sticker_center_top }}</option>
                      <option value="center" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'center' ? 'selected="selected"' : '' }}>{{ sticker_center }}</option>
                      <option value="center-bottom" {{ status_description[language['language_id']]['sticker'] is defined and status_description[language['language_id']]['sticker'] == 'center-bottom' ? 'selected="selected"' : '' }}>{{ sticker_center_bottom }}</option>
                    </select>  

                  </td>
                </tr>
                
                <tr>
                  <td>{{ sort_order }}</td>
                  <td><input type="text" name="status_description[{{ language['language_id'] }}][sort_order]" size="100" value="{{ status_description[language['language_id']]['sort_order'] is defined ? status_description[language['language_id']]['sort_order'] : '' }}" class="form-control" />
                  </td>
                </tr>
                
                <tr>
                  <td>{{ status_type }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][type]" class="form-control" >
                      <option value="image" {{ status_description[language['language_id']]['type'] is defined and status_description[language['language_id']]['type'] == 'image' ? 'selected="selected"' : '' }}>{{ status_type_image }}</option>
                      <option value="text" {{ status_description[language['language_id']]['type'] is defined and status_description[language['language_id']]['type'] == 'text' ? 'selected="selected"' : '' }}>{{ status_type_text }}</option>
                    </select>  

                  </td>
                </tr>

                <tr>
                  <td><b>{{ status_text }}</b></td>
                  <td>
                  </td>
                </tr>								
								
                <tr>
                  <td>{{ status_text_type }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][text_type]" class="form-control" >
                      <option value="rectangle" {{ status_description[language['language_id']]['text_type'] is defined and status_description[language['language_id']]['text_type'] == 'rectangle' ? 'selected="selected"' : '' }}>{{ status_text_rectangle }}</option>
                      <option value="oval" {{ status_description[language['language_id']]['text_type'] is defined and status_description[language['language_id']]['text_type'] == 'oval' ? 'selected="selected"' : '' }}>{{ status_text_oval }}</option>
                      <option value="circle" {{ status_description[language['language_id']]['text_type'] is defined and status_description[language['language_id']]['text_type'] == 'circle' ? 'selected="selected"' : '' }}>{{ status_text_circle }}</option>
                      <option value="circle_corner" {{ status_description[language['language_id']]['text_type'] is defined and status_description[language['language_id']]['text_type'] == 'circle_corner' ? 'selected="selected"' : '' }}>{{ status_text_circle_corner }}</option>
											{% for type in status_text_custom_types %} 
											<option value="{{ type }}" {{ status_description[language['language_id']]['text_type'] is defined and status_description[language['language_id']]['text_type'] == type ? 'selected="selected"' : '' }}>                        
                        {{ attribute(_context, 'status_text_' ~ type) is defined ? attribute(_context, 'status_text_' ~ type) : type }}
                      </option>											 
											{% endfor %}
                    </select>  

                  </td>
                </tr>
								
                <tr>
                  <td>{{ status_type_font_color }}</td>
                  <td>
										<div class="input-group colorpicker-component colorpicker-input">
										  <input type="text" name="status_description[{{ language['language_id'] }}][font_color]" value="{{ status_description[language['language_id']]['font_color'] is defined ? status_description[language['language_id']]['font_color'] : '#ffffff' }}" class="form-control" />
											<span class="input-group-addon"><i></i></span>
										</div>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_type_background_color }}</td>
                  <td>
										<div class="input-group colorpicker-component colorpicker-input">
										  <input type="text" name="status_description[{{ language['language_id'] }}][background_color]" value="{{ status_description[language['language_id']]['background_color'] is defined ? status_description[language['language_id']]['background_color'] : '#ff5252' }}" class="form-control" />
											<span class="input-group-addon"><i></i></span>
										</div>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_type_border_color }}</td>
                  <td>
										<div class="input-group colorpicker-component colorpicker-input">
										  <input type="text" name="status_description[{{ language['language_id'] }}][border_color]" value="{{ status_description[language['language_id']]['border_color'] is defined ? status_description[language['language_id']]['border_color'] : '' }}" class="form-control" />
											<span class="input-group-addon"><i></i></span>
										</div>
                  </td>
                </tr>

                <tr>
                  <td><b>{{ status_auto }}</b></td>
                  <td>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_attribute }}</td>
                  <td>
                    <div class="input-group">
                      <input type="text" name="status_description[{{ language['language_id'] }}][attribute_name]" value="{{ status_description[language['language_id']]['attribute_name'] is defined ? status_description[language['language_id']]['attribute_name'] : '' }}" class="form-control" />
                      <input type="hidden" name="status_description[{{ language['language_id'] }}][attribute_id]" value="{{ status_description[language['language_id']]['attribute_id'] is defined ? status_description[language['language_id']]['attribute_id'] : '' }}" class="form-control" />
                      <span class="input-group-btn">
                        <a onclick="delete_attribute({{ language['language_id'] }}); return false;" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger"><i class="fa fa-trash-o"></i></a>
                      </span>
                    </div>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_attribute_value }}<br />{{ status_attribute_value_help }}</td>
                  <td><input type="text" name="status_description[{{ language['language_id'] }}][attribute_value]" size="100" value="{{ status_description[language['language_id']]['attribute_value'] is defined ? status_description[language['language_id']]['attribute_value'] : '' }}" class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_manufacturer }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][manufacturer_id]" class="form-control" >
                      <option value="0" selected="selected">{{ text_none }}</option>
                      {% for manufacturer in manufacturers %} 
                        {% if (status_description[language['language_id']]['manufacturer_id'] is defined and manufacturer['manufacturer_id'] == status_description[language['language_id']]['manufacturer_id']) %} 
                          <option value="{{ manufacturer['manufacturer_id'] }}" selected="selected">{{ manufacturer['name'] }}</option>
                        {% else %} 
                          <option value="{{ manufacturer['manufacturer_id'] }}">{{ manufacturer['name'] }}</option>
                        {% endif %} 
                      {% endfor %} 
                    </select>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_category }}</td>
                  <td>
                    <select name="status_description[{{ language['language_id'] }}][category_id]" class="form-control" >
                      <option value="0" selected="selected">{{ text_none }}</option>
                      {% for product_category in categories %} 
                        {% if (status_description[language['language_id']]['category_id'] is defined and product_category['category_id'] == status_description[language['language_id']]['category_id']) %} 
                          <option value="{{ product_category['category_id'] }}" selected="selected">{{ product_category['name'] }}</option>
                        {% else %} 
                          <option value="{{ product_category['category_id'] }}">{{ product_category['name'] }}</option>
                        {% endif %} 
                      {% endfor %} 
                    </select>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_price }}</td>
                  <td>
                    <div class="col-sm-6">
                      <div class="col-sm-2">
                        {{ status_price_from }}: 
                      </div>
                      <div class="col-sm-10">
                        <input type="text" name="status_description[{{ language['language_id'] }}][price_from]" size="20" value="{{ status_description[language['language_id']]['price_from'] is defined ? status_description[language['language_id']]['price_from'] : '' }}" class="form-control" /> 
                      </div>
                    </div>
                    <div class="col-sm-6">
                      <div class="col-sm-2">
                        {{ status_price_to }}: 
                      </div>
                      <div class="col-sm-10">
                        <input type="text" name="status_description[{{ language['language_id'] }}][price_to]" size="20" value="{{ status_description[language['language_id']]['price_to'] is defined ? status_description[language['language_id']]['price_to'] : '' }}" class="form-control" />
                      </div>
                    </div>
                  </td>
                </tr>

                <tr>
                  <td>{{ status_stock }}</td>
                  <td>
                    <div class="col-sm-6">
                      <div class="col-sm-2">
                        {{ status_stock_from }}: 
                      </div>
                      <div class="col-sm-10">
                        <input type="text" name="status_description[{{ language['language_id'] }}][stock_from]" size="20" value="{{ status_description[language['language_id']]['stock_from'] is defined ? status_description[language['language_id']]['stock_from'] : '' }}" class="form-control" /> 
                      </div>
                    </div>
                    <div class="col-sm-6">
                      <div class="col-sm-2">
                        {{ status_stock_to }}: 
                      </div>
                      <div class="col-sm-10">
                        <input type="text" name="status_description[{{ language['language_id'] }}][stock_to]" size="20" value="{{ status_description[language['language_id']]['stock_to'] is defined ? status_description[language['language_id']]['stock_to'] : '' }}" class="form-control" />
                      </div>
                    </div> 
                  </td>
                </tr>

                <tr>
                  <td>{{ status_new }}</td>
                  <td><input type="checkbox" name="status_description[{{ language['language_id'] }}][new]" value="1" {{ status_description[language['language_id']]['new'] is defined and status_description[language['language_id']]['new'] ? 'checked="checked"' : '' }} class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_bestseller }}</td>
                  <td><input type="checkbox" name="status_description[{{ language['language_id'] }}][bestseller]" value="1" {{ status_description[language['language_id']]['bestseller'] is defined and status_description[language['language_id']]['bestseller'] ? 'checked="checked"' : '' }} class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_popular }}</td>
                  <td><input type="checkbox" name="status_description[{{ language['language_id'] }}][popular]" value="1" {{ status_description[language['language_id']]['popular'] is defined and status_description[language['language_id']]['popular'] ? 'checked="checked"' : '' }} class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_special }}</td>
                  <td><input type="checkbox" name="status_description[{{ language['language_id'] }}][special]" value="1" {{ status_description[language['language_id']]['special'] is defined and status_description[language['language_id']]['special'] ? 'checked="checked"' : '' }} class="form-control" />
                  </td>
                </tr>

                <tr>
                  <td>{{ status_promotion }}<br/>{{ status_promotion_help }}</td>
                  <td><input type="checkbox" name="status_description[{{ language['language_id'] }}][promotion]" value="1" {{ status_description[language['language_id']]['promotion'] is defined and status_description[language['language_id']]['promotion'] ? 'checked="checked"' : '' }} class="form-control" /> <br/> {{ status_promotion_image }}<input type="checkbox" name="status_description[{{ language['language_id'] }}][promotion_image]" value="1" {{ status_description[language['language_id']]['promotion_image'] is defined and status_description[language['language_id']]['promotion_image'] ? 'checked="checked"' : '' }} class="form-control" />
                  </td>
                </tr>

              </table>
            </div>
            
            {% endfor %} 
          </div>
        </form>  
      </div>
    </div>
  </div>
  
</div>

<script type="text/javascript"><!--

$('#language a:first').tab('show');
    
function attribute_autocomplete(language_id) {
	$('input[name=\'status_description[' + language_id + '][attribute_name]\']').autocomplete({
		source: function(request, response) {
			$.ajax({
				url: 'index.php?route=catalog/attribute/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
				dataType: 'json',
				success: function(json) {	
					response($.map(json, function(item) {
						return {
              label: item['name'],
              value: item['attribute_id']
						}
					}));
				}
			});
		}, 
		select: function(item) {
      $('input[name=\'status_description[' + language_id + '][attribute_name]\']').attr('value', item['label']);
      $('input[name=\'status_description[' + language_id + '][attribute_name]\']').val(item['label']);
			$('input[name=\'status_description[' + language_id + '][attribute_id]\']').attr('value', item['value']);

			return false;
		}
	});
}

function delete_attribute(language_id) {
	$('input[name=\'status_description[' + language_id + '][attribute_name]\']').attr('value', '');
  $('input[name=\'status_description[' + language_id + '][attribute_name]\']').val('');
	$('input[name=\'status_description[' + language_id + '][attribute_id]\']').attr('value', '');
}

function attribute_name_autocomplete(language_id) {
	$('input[name=\'status_description[' + language_id + '][name_attribute]\']').autocomplete({
		source: function(request, response) {
			$.ajax({
				url: 'index.php?route=catalog/attribute/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
				dataType: 'json',
				success: function(json) {	
					response($.map(json, function(item) {
						return {
              label: item['name'],
              value: item['attribute_id']
						}
					}));
				}
			});
		}, 
		select: function(item) {
      $('input[name=\'status_description[' + language_id + '][name_attribute]\']').attr('value', item['label']);
      $('input[name=\'status_description[' + language_id + '][name_attribute]\']').val(item['label']);
			$('input[name=\'status_description[' + language_id + '][name_attribute_id]\']').attr('value', item['value']);

			return false;
		}
	});
}

function delete_name_attribute(language_id) {
	$('input[name=\'status_description[' + language_id + '][name_attribute]\']').attr('value', '');
  $('input[name=\'status_description[' + language_id + '][name_attribute]\']').val('');
	$('input[name=\'status_description[' + language_id + '][name_attribute_id]\']').attr('value', '');
}

$(function() {
  $('.colorpicker-input').colorpicker();
});

//--></script>
 
{% for language in languages %} 
<script type="text/javascript"><!--
  attribute_autocomplete({{ language['language_id'] }});
	attribute_name_autocomplete({{ language['language_id'] }});
//--></script> 
{% endfor %} 

{{ footer }}
