{{ header }}{{ column_left }}
<div id="content">
  <div class="loading-wrapper">
    <div class="loading-spinner"><i class="fa fa-spinner fa-pulse fa-2x"></i></div>
  </div>
  <div class="message-wrapper"></div>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right form-inline">
        {% if translator is defined and translator %}
          <div id="google-translate"></div>
          <script type="text/javascript">
              function googleTranslateElementInit() {
                  new google.translate.TranslateElement({pageLanguage: 'en', layout: google.translate.TranslateElement.InlineLayout.VERTICAL, autoDisplay: false, multilanguagePage: true}, 'google-translate');
              }
          </script>
          <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
        {% endif %}
        {% if stores|length > 1 %}
          <div class="form-group multi-store" {% if (multi_store is null or multi_store == 0) and store_id == 0 %}style="display: none;"{% endif %}>
            <label>{{ entry_store }}</label>
            <select name="store_id" class="form-control store" data-store_id="{{ store_id }}" data-confirm="{{ text_page_refresh }}">
              {% for store in stores %}
                <option value="{{ store.store_id }}" {% if store.store_id == store_id %}selected="selected"{% endif %}>{{ store.name }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        <button type="button" onclick="changeTranslator('{{ text_page_refresh }}')" data-toggle="tooltip" title="{{ tooltip_translator }}" class="btn btn-default {% if translator is defined and translator %}active{% endif %}"><i class="fa fa-language"></i></button>
        <button type="button" onclick="submitForm($(this))" data-session="{{ text_session_expired }}"  data-loading-text="<i class='fa fa-spinner fa-pulse'></i>" data-toggle="tooltip" title="{{ tooltip_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <button type="button" onclick="window.location.href = $('.breadcrumb li').eq(-2).children('a').attr('href')" data-toggle="tooltip" title="{{ tooltip_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></button>
      </div>
      <h1><i class="fa fa-line-chart"></i> {{ text_title }}
        <div class="e-version">{{ e_version }}</div>
        <div class="e-author"><a href="{{ author_link }}" target="_blank">by {{ author_name }}</a></div>
      </h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <div class="panel panel-default">
      <div class="panel-body">
        <div class="gmp-group">
          <div class="alert alert-warning alert-validation-mode" role="alert" style="display: {% if type == 0 and validation_mode %}block{% else %}none{% endif %};"><i class="fa fa-exclamation-triangle"></i> {{ text_validation_enabled }}</div>
        </div>
        {% if multi_store_disabled %}
          <div class="alert alert-warning alert-multistore-disabled" role="alert"><i class="fa fa-exclamation-triangle"></i> {{ text_multi_store_disabled }}</div>
        {% endif %}
        <form id="form-general" action="{{ action }}" class="form-horizontal">
          <div class="col-xs-2">
            <ul class="nav nav-tabs tabs-left">
              <li class="active"><a href="#tab-general" data-toggle="tab"><i class="fa fa-home tab-icon"></i> {{ tab_general }}*</a></li>
              <li><a href="#tab-advanced" data-toggle="tab"><i class="fa fa-expand tab-icon"></i> {{ tab_advanced }}</a></li>
              <li><a href="#tab-view" data-toggle="tab"><i class="fa fa-eye tab-icon"></i> {{ tab_view }}</a></li>
              <li><a href="#tab-select" data-toggle="tab"><i class="fa fa-mouse-pointer tab-icon"></i> {{ tab_select }}</a></li>
              <li><a href="#tab-wish" data-toggle="tab"><i class="fa fa-heart tab-icon"></i> {{ tab_wish }}</a></li>
              <li><a href="#tab-cart" data-toggle="tab"><i class="fa fa-shopping-cart tab-icon"></i> {{ tab_cart }}</a></li>
              <li><a href="#tab-checkout" data-toggle="tab"><i class="fa fa-truck tab-icon"></i> {{ tab_checkout }}</a></li>
              <li><a href="#tab-purchase" data-toggle="tab" class="{% if warning_purchase_tracking_status %}bg-warning{% endif %}"><i class="fa fa-money tab-icon"></i> {{ tab_purchase }}*</a></li>
              <li><a href="#tab-refund" data-toggle="tab"><i class="fa fa-reply tab-icon"></i> {{ tab_refund }}*</a></li>
              <li><a href="#tab-promotion" data-toggle="tab"><i class="fa fa-bullhorn tab-icon"></i> {{ tab_promotion }}</a></li>
              <li><a href="#tab-custom-definition" data-toggle="tab"><i class="fa fa-arrows-alt tab-icon"></i> {{ tab_custom_definition }}</a></li>
              <li><a href="#tab-filter" data-toggle="tab"><i class="fa fa-filter tab-icon"></i> {{ tab_filter }}</a></li>
              <li><a href="#tab-log" data-toggle="tab"><i class="fa fa-bars tab-icon"></i> {{ tab_log }}</a></li>
              <li><a href="#tab-help" data-toggle="tab"><i class="fa fa-life-ring tab-icon"></i> {{ tab_help }}{% if store_id == 0 %}*{% endif %}</a></li>
            </ul>
            <small>{{ text_tab_required }}</small>
            <div onclick="$('.dev-mode').slideToggle(500)" style="width: 10px; height: 10px"></div>
          </div>
          <div class="col-xs-10">
            <div class="tab-content">
              <div class="tab-pane tab-left fade in active" id="tab-general">
                <fieldset>
                  <legend>{{ legend_general }}</legend>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-status"><span data-toggle="tooltip" title="{{ tooltip_status }}">{{ entry_status }}</span></label>
                    <div class="col-sm-4">
                      <input type="hidden" name="status" id="input-status" value="{{ status }}" />
                      <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" data-fade=".general-group" data-opacity=".general-opacity-group" class="fa {% if status %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x btn-status" data-toggle="tooltip" title="{{ status ? text_enabled : text_disabled }}"></i>
                    </div>
                    <label class="col-sm-2 control-label" for="input-bulk-status-change">
                      <span data-toggle="tooltip" title="{{ tooltip_bulk_status }}">{{ entry_bulk_status }}</span>
                      <p>({{ text_optional }})</p>
                    </label>
                    <div class="col-sm-4">
                      <input type="hidden" id="input-bulk-status-change" value="0" />
                      <i onclick="changeToggleSwitch($(this));bulkStatusChange($(this));" class="fa fa-toggle-off blue fa-3x" data-toggle="tooltip" title="{{ text_disabled }}"></i>
                    </div>
                  </div>
                  <fieldset class="general-group" {{ (status == false) ? 'style="display: none;"' }}>
                    {% if stores|length > 1 and store_id == 0 %}
                      <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-multi-store"><span data-toggle="tooltip" title="{{ tooltip_multi_store }}">{{ entry_multi_store }}</span></label>
                        <div class="col-sm-10">
                          <input type="hidden" name="multi_store" id="input-multi-store" value="{{ multi_store }}" />
                          <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" data-fade=".multi-store" class="fa {% if multi_store %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ multi_store ? text_enabled : text_disabled }}"></i>
                        </div>
                      </div>
                    {% endif %}
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-type"><span data-toggle="tooltip" title="{{ tooltip_type }}">{{ entry_type }}</span></label>
                      <div class="col-sm-10">
                        <input type="hidden" name="type" id="input-type" value="{{ type }}" />
                        <div class="btn-group btn-group-justified" role="group">
                          <div class="btn-group" role="group">
                            <button type="button" onclick="changeTrackingType($(this), 0)" data-note="{{ note_mp|e }}" class="btn btn-group-type {% if type == 0 %}active{% endif %}">{{ button_mp }}</button>
                          </div>
                          <div class="btn-group" role="group">
                            <button type="button" onclick="changeTrackingType($(this), 1)" data-note="{{ note_gtag|e }}" class="btn btn-group-type {% if type == 1 %}active{% endif %}">{{ button_gtag }}</button>
                          </div>
                          <div class="btn-group" role="group">
                            <button type="button" onclick="changeTrackingType($(this), 2)" data-note="{{ note_gtm|e }}" class="btn btn-group-type {% if type == 2 %}active{% endif %}">{{ button_gtm }}</button>
                          </div>
                        </div>
                        <p class="text-info">{% if type == 0 %}{{ note_mp }}{% elseif type == 1 %}{{ note_gtag }}{% elseif type == 2 %}{{ note_gtm }}{% endif %}</p>
                      </div>
                    </div>
                    <div class="form-group required">
                      <label class="col-sm-2 control-label" for="input-measurement-id"><span data-toggle="tooltip" title="{{ tooltip_measurement_id }}">{{ entry_measurement_id }}</span></label>
                      <div class="col-sm-10">
                        <div class="input-group">
                          <input type="text" name="measurement_id" id="input-measurement-id" value="{{ measurement_id }}" placeholder="G-XXXXXXXXXX" class="form-control notranslate" />
                          <span class="input-group-btn">
                            {% if found_measurement_id %}
                              <button class="btn btn-default" type="button" onclick="$(this).closest('.input-group').find('input').val('{{ found_measurement_id }}')" data-toggle="tooltip" title="{{ tooltip_found_measurement_id }}"><i class="fa fa-refresh" aria-hidden="true"></i></button>
                            {% endif %}
                            <button type="button" class="btn btn-default" onclick="showModalImg('{{ redirect_link }}image&name=measurement-id.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                          </span>
                        </div>
                        <small class="help-block error-measurement_id"></small>
                        <p class="text-info">{{ note_measurement_id }}</p>
                      </div>
                    </div>
                    <div class="form-group required">
                      <label class="col-sm-2 control-label" for="input-measurement-secret"><span data-toggle="tooltip" title="{{ tooltip_measurement_secret }}">{{ entry_measurement_secret }}</span><p>({{ text_gmp_only }})</p></label>
                      <div class="col-sm-10 gmp-group" style="display: {% if type == 0 %}block{% else %}none{% endif %};">
                        <div class="input-group">
                          <input type="text" name="measurement_secret" id="input-measurement-secret" value="{{ measurement_secret }}" placeholder="Secret API Key" class="form-control notranslate" />
                          <span class="input-group-btn">
                            <button type="button" class="btn btn-default" onclick="showModalImg('{{ redirect_link }}image&name=measurement-api-secrets.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                          </span>
                        </div>
                        <small class="help-block error-measurement_secret"></small>
                        <p class="text-info">{{ note_measurement_secret }}</p>
                      </div>
                      <div class="col-sm-10 not-gmp-group" style="display: {% if type == 0 %}none{% else %}block{% endif %};">
                        <p class="form-control-static">{{ text_option_not_available }}</p>
                      </div>
                    </div>
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-validation"><span data-toggle="tooltip" title="{{ tooltip_validation }}">{{ entry_validation }}</span><p>({{ text_gmp_only }})</p></label>
                      <div class="col-sm-9 gmp-group" style="display: {% if type == 0 %}block{% else %}none{% endif %};">
                        <input type="hidden" name="validation_mode" id="input-validation" value="{{ validation_mode }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');changeValidationMode($(this));" data-fadein=".validation-mode-group" class="fa {% if validation_mode %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ validation_mode ? text_enabled : text_disabled }}"></i>
                        <p class="text-info">{{ note_validation_mode }}</p>
                      </div>
                      <div class="col-sm-9 not-gmp-group" style="display: {% if type == 0 %}none{% else %}block{% endif %};">
                        <p class="form-control-static">{{ text_option_not_available }}</p>
                      </div>
                      <div class="col-sm-1">
                        <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=validation-mode-logs.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                      </div>
                    </div>
                    <div class="form-group debug-view-mode" style="opacity: {% if validation_mode and type == 0 %}0.4{% else %}1{% endif %};">
                      <label class="col-sm-2 control-label" for="input-debug-mode"><span data-toggle="tooltip" title="{{ tooltip_debug }}">{{ entry_debug }}</span></label>
                      <div class="col-sm-9">
                        <input type="hidden" name="debug_mode" id="input-debug-mode" value="{{ debug_mode }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" class="fa {% if debug_mode %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ debug_mode ? text_enabled : text_disabled }}"></i>
                        <p class="text-info not-gtm-group" style="display: {% if type == 2 %}none{% else %}block{% endif %};">{{ note_debug_mode }}</p>
                        <p class="text-info gtm-group" style="display: {% if type == 2 %}block{% else %}none{% endif %};">{{ note_debug_mode_gtm }}</p>
                      </div>
                      <div class="col-sm-1">
                        <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=ga-debugview.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                      </div>
                    </div>
                    <div class="form-group dev-mode" style="display: none;">
                      <label class="col-sm-2 control-label" for="input-dev-mode">Developer Mode</label>
                      <div class="col-sm-10">
                        <input type="hidden" name="dev_mode" id="input-dev-mode" value="{{ dev_mode }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}')" class="fa {% if dev_mode %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ dev_mode ? text_enabled : text_disabled }}"></i>
                      </div>
                    </div>
                  </fieldset>
                </fieldset>
              </div>
              <div class="tab-pane tab-left fade general-opacity-group {% if status == false %}opacity-on{% endif %}" id="tab-advanced">
                <fieldset>
                  <legend>{{ legend_advanced }}</legend>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-js_position"><span data-toggle="tooltip" title="{{ tooltip_js_position }}">{{ entry_js_position }}</span></label>
                    <div class="col-sm-9">
                      <select name="js_position" id="input-js_position" class="form-control">
                        <option value="0" {% if js_position == 0 %}selected="selected"{% endif %}>{{ text_js_position_0 }}</option>
                        <option value="1" {% if js_position == 1 %}selected="selected"{% endif %}>{{ text_js_position_1 }}</option>
                        <option value="2" {% if js_position == 2 %}selected="selected"{% endif %}>{{ text_js_position_2 }}</option>
                        <option value="3" {% if js_position == 3 %}selected="selected"{% endif %}>{{ text_js_position_3 }}</option>
                      </select>
                    </div>
                  </div>
                  {% if themes %}
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-theme"><span data-toggle="tooltip" title="{{ tooltip_theme }}">{{ entry_theme }}</span></label>
                    <div class="col-sm-9">
                      <select name="theme" id="input-theme" class="form-control">
                        <option value="0" {% if theme is null or theme == '0' %}selected="selected"{% endif %}>{{ text_default }}</option>
                        {% for theme_item in themes %}
                          <option value="{{ theme_item }}" {% if theme == theme_item %}selected="selected"{% endif %}>{{ theme_item|capitalize }}</option>
                        {% endfor %}
                      </select>
                      <p class="text-info">{{ note_theme }}</p>
                    </div>
                  </div>
                  {% endif %}
                  {% if currencies|length > 2 %}
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-currency"><span data-toggle="tooltip" title="{{ tooltip_currency }}">{{ entry_currency }}</span></label>
                      <div class="col-sm-9">
                        <select name="currency" id="input-currency" class="form-control">
                          {% for currency_item in currencies %}
                            <option value="{{ currency_item.code }}" {% if currency == currency_item.code %}selected="selected"{% endif %}>
                              {{ currency_item.title }} {{ currency_item.code ? '(' ~ currency_item.code ~ ')' }}
                            </option>
                          {% endfor %}
                        </select>
                        <div class="error-wrapper error_currency"></div>
                      </div>
                      <div class="col-sm-1">
                        <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=currency-option.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                      </div>
                    </div>
                  {% endif %}
                  {% if languages|length > 2 %}
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-language"><span data-toggle="tooltip" title="{{ tooltip_language }}">{{ entry_language }}</span></label>
                      <div class="col-sm-9">
                        <select name="language_id" id="input-language" class="form-control">
                          {% for language in languages %}
                            <option value="{{ language.language_id }}" {% if language_id == language.language_id %}selected="selected"{% endif %}>
                              {{ language.name }} {{ language.code ? '(' ~ language.code ~ ')' }}
                            </option>
                          {% endfor %}
                        </select>
                        <p class="text-info"></p>
                      </div>
                      <div class="col-sm-1">
                        <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=language-option.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                      </div>
                    </div>
                  {% endif %}
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-affiliation"><span data-toggle="tooltip" title="{{ tooltip_affiliation }}">{{ entry_affiliation }}</span></label>
                    <div class="col-sm-9">
                      <input type="text" name="affiliation" value="{{ affiliation }}" placeholder="{{ config_name }}" id="input-affiliation" class="form-control notranslate" />
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=affiliation-option.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-client-id"><span data-toggle="tooltip" title="{{ tooltip_client_id }}">{{ entry_client_id }}</span></label>
                    <div class="col-sm-9">
                      {% if default_client_id %}
                      <div class="input-group">
                        {% endif %}
                        <input type="text" name="client_id" value="{{ client_id }}" placeholder="{{ client_id }}" id="input-client-id" class="form-control notranslate" />
                        {% if default_client_id %}
                        <span class="input-group-btn">
                          <button class="btn btn-default" type="button" onclick="$(this).closest('.input-group').find('input').val('{{ default_client_id }}')" data-toggle="tooltip" title="{{ tooltip_default_client_id }}"><i class="fa fa-refresh" aria-hidden="true"></i></button>
                        </span>
                      </div>
                      {% endif %}
                      <p class="text-info">{{ note_client_id }}</p>
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=ga-client-id.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-extended-list"><span data-toggle="tooltip" title="{{ tooltip_extended_list }}">{{ entry_extended_list }}</span></label>
                    <div class="col-sm-9">
                      <input type="hidden" name="extended_list" id="input-extended-list" value="{{ extended_list }}" />
                      <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" class="fa {% if extended_list %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ extended_list ? text_enabled : text_disabled }}"></i>
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=extended-list-parameters.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-list-limit"><span data-toggle="tooltip" title="{{ tooltip_list_limit }}">{{ entry_list_limit }}</span><p>({{ text_gmp_only }})</p></label>
                    <div class="col-sm-9 gmp-group" style="display: {% if type == 0 %}block{% else %}none{% endif %};">
                      <div class="input-group">
                        <input type="text" name="list_limit" id="input-list-limit" value="{{ list_limit }}" placeholder="26" class="form-control notranslate" />
                        <div class="input-group-btn">
                          <input type="hidden" name="list_limit_skip" value="{{ list_limit_skip }}">
                          <button type="button" class="btn btn-success dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">{% if list_limit_skip %}{{ text_list_limit_skip }}{% else %}{{ text_list_limit_multi_event }}{% endif %} <span class="caret"></span></button>
                          <ul class="dropdown-menu dropdown-menu-right">
                            <li><a onclick="$('input[name=list_limit_skip]').val(1);$(this).closest('.input-group-btn').find('button').html($(this).html() + ' <span class=\'caret\'></span>');">{{ text_list_limit_skip }}</a></li>
                            <li><a onclick="$('input[name=list_limit_skip]').val(0);$(this).closest('.input-group-btn').find('button').html($(this).html() + ' <span class=\'caret\'></span>');">{{ text_list_limit_multi_event }}</a></li>
                          </ul>
                        </div>
                      </div>
                    </div>
                    <div class="col-sm-9 not-gmp-group" style="display: {% if type == 0 %}none{% else %}block{% endif %};">
                      <p class="form-control-static">{{ text_option_not_available }}</p>
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=items-per-list.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <legend class="sub-legend">{{ sub_legend_item }}</legend>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-product-id">
                      <span data-toggle="tooltip" title="{{ tooltip_product_id }}">{{ entry_product_id }}</span>
                    </label>
                    <div class="col-sm-9">
                      <select name="product_id" id="input-product-id" class="form-control">
                        <option value="" {% if product_id is null or product_id == '' %}selected="selected"{% endif %}>{{ text_product_id }}</option>
                        {% for identifier in identifiers %}
                          <option value="{{ identifier }}" {% if product_id is defined and product_id == identifier %}selected="selected"{% endif %}>{{ identifier }}</option>
                        {%  endfor %}
                      </select>
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=item-id-option.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-product-category"><span data-toggle="tooltip" title="{{ tooltip_product_category }}">{{ entry_product_category }}</span></label>
                    <div class="col-sm-9">
                      <select name="product_category" id="input-product-category" class="form-control">
                        <option value="0" {% if product_category is null or product_category == 0 %}selected="selected"{% endif %}>{{ text_product_category_0 }}</option>
                        <option value="1" {% if product_category is defined and product_category == 1 %}selected="selected"{% endif %}>{{ text_product_category_1 }}</option>
