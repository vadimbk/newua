                  <fieldset class="promotion-group" style="display: {% if promotion_status %}block{% else %}none{% endif %};">
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-promotion-simple"><span data-toggle="tooltip" title="{{ tooltip_promotion_simple }}">{{ entry_promotion_simple }}</span></label>
                      <div class="col-sm-10">
                        <input type="hidden" name="promotion_simple" id="input-promotion-simple" value="{{ promotion_simple }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" class="fa {% if promotion_simple %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ promotion_simple ? text_enabled : text_disabled }}"></i>
                        <p class="text-info"></p>
                      </div>
                    </div>
                  </fieldset>
                </fieldset>
              </div>
              <div class="tab-pane tab-left fade general-opacity-group {% if status == false %}opacity-on{% endif %}" id="tab-custom-definition">
                <fieldset>
                  <legend>{{ legend_custom_definition }}</legend>
                  <div class="alert alert-info" role="alert"><i class="fa fa-exclamation-triangle"></i> {{ text_alert_custom_definition }}</div>
                  <table id="custom-definition" class="table table-striped table-bordered table-hover">
                    <thead>
                    <tr>
                      <td class="text-left">{{ entry_object }}</td>
                      <td class="text-left">{{ entry_parameter_value }}</td>
                      <td class="text-left">{{ entry_parameter_name }}</td>
                      <td></td>
                    </tr>
                    </thead>
                    <tbody>
                    {% set definition_row = 1 %}
                    {% if custom_definition %}
                      {% set definition_count = 125 - custom_definition|length %}
                    {% else %}
                      {% set definition_count = 125 %}
                    {% endif %}
                    {% for definition in custom_definition %}
                      <tr id="definition-row{{ definition_row }}">
                        <td class="text-left" style="width: 20%;">
                          <select name="custom_definition[{{ definition_row }}][object]" onchange="changeCdObject({{ definition_row }})" id="select-object{{ definition_row }}" class="form-control">
                            <option value="0" {% if definition.object is null or definition.object == 0 %}selected="selected"{% endif %}>{{ text_user_scope_customer }}</option>
                            <option value="1" {% if definition.object == 1 %}selected="selected"{% endif %}>{{ text_event_scope_order }}</option>
                            <!--<option value="2" {% if definition.object == 2 %}selected="selected"{% endif %}>{{ text_event_scope_product }}</option>-->
                          </select>
                        </td>
                        <td class="text-right" style="width: 30%;">
                          <select name="custom_definition[{{ definition_row }}][value]" onchange="changeCdValue({{ definition_row }})" id="select-value{{ definition_row }}" class="form-control">
                            {% if definition.object is null or definition.object == 0 %}
                              {% set table_columns = customer_columns %}
                            {% elseif definition.object == 1 %}
                              {% set table_columns = order_columns %}
                            {% elseif definition.object == 2 %}
                              {% set table_columns = product_columns %}
                            {% endif %}
                            {% for table_column in table_columns %}
                              <option value="{{ table_column }}" {% if definition.value == table_column %}selected="selected"{% endif %}>{{ table_column }}</option>
                            {% endfor %}
                          </select>
                        </td>
                        <td class="text-left">
                          <input type="text" name="custom_definition[{{ definition_row }}][name]" value="{{ definition.name }}" placeholder="{{ entry_parameter_name }}" id="input-name{{ definition_row }}" class="form-control" />
                        </td>
                        <td class="text-right"><button type="button" onclick="$('#definition-row{{ definition_row }}').remove();$('#definition-count').html(parseInt($('#definition-count').html())+1);increaseDefinitionCount();" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
                      </tr>
                      {% set definition_row = definition_row + 1 %}
                    {% endfor %}
                    </tbody>
                    <tfoot>
                    <tr>
                      <td colspan="3"><span id="definition-count">{{ definition_count }}</span> {{ text_definition_left }} <i class="fa fa-info-circle" data-toggle="tooltip" title="{{ tooltip_custom_definition_quota }}"></i></td>
                      <td class="text-right"><button type="button" onclick="addDefinitionRow();" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
                    </tr>
                    </tfoot>
                  </table>
                </fieldset>
              </div>
              <div class="tab-pane tab-left fade general-opacity-group {% if status == false %}opacity-on{% endif %}" id="tab-filter">
                <fieldset>
                  <legend>{{ legend_data_filters }}</legend>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-exclude-u-agent"><span data-toggle="tooltip" title="{{ tooltip_exclude_u_agent }}">{{ entry_exclude_u_agent }}</span></label>
                    <div class="col-sm-10">
                      <textarea wrap="off" rows="1" name="exclude_u_agent" id="input-exclude-u-agent" class="form-control notranslate">{{ exclude_u_agent }}</textarea>
                      <p class="text-info">{{ text_example }}: <span style="color: #FFA500;">bot|crawl|slurp|spider|mediapartners|google</span>
                        <a onclick="addFilterValue('exclude_u_agent', 'bot|crawl|slurp|spider|mediapartners|google', '|');" style="cursor: pointer;">
                          <i class="fa fa-plus-circle fa-btn" aria-hidden="true" data-toggle="tooltip" title="{{ button_add_this }}"></i>
                        </a>
                        <a class="pull-right" onclick="$(this).closest('.form-group').find('textarea').val('')">
                          <i class="fa fa-trash-o fa-btn" aria-hidden="true" data-toggle="tooltip" title="{{ button_clear }}"></i>
                        </a>
                      </p>
                    </div>
                  </div>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-ip-filter"><span data-toggle="tooltip" title="{{ tooltip_exclude_ip }}">{{ entry_exclude_ip }}</span></label>
                    <div class="col-sm-10">
                      <textarea name="exclude_ip" id="input-ip-filter" class="form-control notranslate" rows="1" wrap="off">{{ exclude_ip }}</textarea>
                      <p class="text-info">{{ text_example }} {{ text_your_ip }}:
                        <span style="color: #FFA500;">{{ current_ip }}</span>
                        <a onclick="addFilterValue('exclude_ip', '{{ current_ip }}', '\n');"><i class="fa fa-plus-circle fa-btn" aria-hidden="true" data-toggle="tooltip" title="{{ button_add_this }}"></i></a>
                        <a class="pull-right" onclick="$(this).closest('.form-group').find('textarea').val('')">
                          <i class="fa fa-trash-o fa-btn" aria-hidden="true" data-toggle="tooltip" title="{{ button_clear }}"></i>
                        </a>
                      </p>
                    </div>
                  </div>
                  {% if store_id == 0 %}
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-exclude-admin"><span data-toggle="tooltip" title="{{ tooltip_exclude_admin }}">{{ entry_exclude_admin }}</span></label>
                      <div class="col-sm-10">
                        <input type="hidden" name="exclude_admin" id="input-exclude-admin" value="{{ exclude_admin }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" class="fa {% if exclude_admin %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ exclude_admin ? text_enabled : text_disabled }}"></i>
                        <p class="text-info">{{ note_exclude_admin }}</p>
                      </div>
                    </div>
                  {% endif %}
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-traffic-type"><span data-toggle="tooltip" title="{{ tooltip_traffic_type }}">{{ entry_traffic_type }}</span></label>
                    <div class="col-sm-10">
                      <div class="input-group">
                        <input type="text" name="traffic_type" id="input-traffic-type" value="{{ traffic_type }}" placeholder="" id="input-traffic_type" class="form-control notranslate" />
                        <span class="input-group-btn">
                            <button type="button" class="btn btn-default" onclick="showModalImg('{{ redirect_link }}image&name=traffic-type.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                          </span>
                      </div>
                      <small class="help-block error-traffic_type"></small>
                      <p class="text-info">{{ note_traffic_type }}</p>
                    </div>
                  </div>
                </fieldset>
              </div>
              <div class="tab-pane tab-left fade general-opacity-group {% if status == false %}opacity-on{% endif %}" id="tab-log">
                <fieldset>
                  <legend>{{ legend_log }}</legend>
                  <div class="form-group">
                    <label class="col-sm-2 control-label" for="input-log"><span data-toggle="tooltip" title="{{ tooltip_log_status }}">{{ entry_status }}</span></label>
                    <div class="col-sm-9">
                      <input type="hidden" name="log" id="input-log" value="{{ log }}" />
                      <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" data-fade=".log-group" class="fa {% if log %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ log ? text_enabled : text_disabled }}"></i>
                    </div>
                    <div class="col-sm-1">
                      <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=logs.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                    </div>
                  </div>
                  <fieldset class="log-group" style="display: {% if log %}block{% else %}none{% endif %};">
                    <div class="form-group">
                      <label class="col-sm-2 control-label" for="input-extended-log"><span data-toggle="tooltip" title="{{ tooltip_extended_log }}">{{ entry_extended_log }}</span></label>
                      <div class="col-sm-9">
                        <input type="hidden" name="extended_log" id="input-extended-log" value="{{ extended_log }}" />
                        <i onclick="changeToggleSwitch($(this), '{{ text_enabled }}', '{{ text_disabled }}');" class="fa {% if extended_log %} fa-toggle-on{% else %} fa-toggle-off{% endif %} fa-3x" data-toggle="tooltip" title="{{ extended_log ? text_enabled : text_disabled }}"></i>
                      </div>
                      <div class="col-sm-1">
                        <button type="button" class="btn btn-default pull-right" onclick="showModalImg('{{ redirect_link }}image&name=extended-logs.jpg')" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                      </div>
                    </div>
                    <div class="form-group">
                      <div class="col-sm-12">
                        <textarea wrap="off" rows="18" id="logs" class="form-control notranslate">{{ logs }}</textarea>
                        <br>
                        <div class="text-center">
                          <button type="button" class="btn btn-sm btn-info" onclick="refreshELog($(this), '{{ refresh_log_action }}');" data-loading-text="<i class='fa fa-spinner fa-pulse'></i> {{ button_refresh }}"><i class="fa fa-refresh"></i> {{ button_refresh }}</button>
                          <button type="button" class="btn btn-sm btn-warning" onclick="clearELog($(this), '{{ clear_log_action }}');" data-loading-text="<i class='fa fa-spinner fa-pulse'></i> {{ button_clear }}"><i class="fa fa-trash-o"></i> {{ button_clear }}</button>
                        </div>
                      </div>
                    </div>
                  </fieldset>
                </fieldset>
              </div>
              <div class="tab-pane tab-left fade" id="tab-help">
                <div class="btn-group btn-group-justified" data-toggle="buttons">
                  {% if store_id == 0 %}
                    <a href="#tab-license" class="btn btn-default active" data-toggle="tab"><input type="radio" /><i class="fa fa-lock"></i> {{ button_license }}</a>
                  {% endif %}
                  <a href="#tab-info" class="btn btn-default{% if store_id != 0 %} active{% endif %}" data-toggle="tab"><input type="radio" /><i class="fa fa-info-circle"></i> {{ button_info }}</a>
                  <a href="#tab-support" class="btn btn-default" data-toggle="tab"><input type="radio" /><i class="fa fa-ticket"></i> {{ button_support }}</a>
                </div>
                <div class="tab-content">
                  {% if store_id == 0 %}
                    <div class="tab-pane fade in active" id="tab-license">
                      <br/>
                      <div class="alert alert-info" role="alert"><i class="fa fa-info-circle" aria-hidden="true"></i> {{ text_license_alert }}</div>
                      <div class="col-lg-4 col-lg-offset-4 text-center">
                        <div class="form-group required">
                          <label class="control-label" for="input-license-id"><span data-toggle="tooltip" title="{{ tooltip_license_id }}">{{ entry_license_id }}</span></label>
                          <div class="input-group">
                            <input type="text" name="license_id" id="input-license-id" value="{{ license_id }}" placeholder="" class="form-control notranslate text-center" />
                            <span class="input-group-btn">
                                <button onclick="showModalImg('{{ redirect_link }}image&name=opencart-oirder-id.jpg');" class="btn btn-default" type="button" data-toggle="tooltip" title="{{ tooltip_show_demo }}"><i class="fa fa-eye" aria-hidden="true"></i></button>
                              </span>
                          </div>
                          <small class="help-block error-license_id"></small>
                        </div>
                      </div>
                    </div>
                  {% endif %}
                  <div class="tab-pane fade{% if store_id != 0 %} in active{% endif %}" id="tab-info">
                    <br/>
                    <ul class="col-sm-4 list-group list-group-flush">
                      <li class="list-group-item">{{ text_ext }} : <a href="{{ redirect_link }}page" target="_blank">{{ text_title }}</a></li>
                      <li class="list-group-item">{{ text_version }} : {{ e_version }}</li>
                      <li class="list-group-item">{{ text_author }} : <a href="{{ author_link }}" target="_blank">{{ author_name }}</a></li>
                      <li class="list-group-item">{{ text_installation_date }} : {{ installation_date }}</li>
                    </ul>
                    <div class="col-sm-4">
                      <a href="{{ redirect_link }}page" target="_blank" class="btn btn-info btn-block">{{ button_official_page }}</a>
                      <a href="{{ redirect_link }}more" target="_blank" class="btn btn-success btn-block">{{ button_more_extensions }}</a>
                      <a href="{{ redirect_link }}faq&opencart={{ oc_version }}" target="_blank" class="btn btn-warning btn-block">{{ button_faq }}</a>
                    </div>
                    <div class="col-sm-4">
                      <a href="{{ redirect_link }}changelog" target="_blank" class="btn btn-primary btn-block">{{ button_changelog }}</a>
                      <a href="{{ redirect_link }}demo" target="_blank" class="btn btn-default btn-block">{{ button_demo_site }}</a>
                      <a href="{{ redirect_link }}admin-demo" target="_blank" class="btn btn-default btn-block">{{ button_demo_admin }}</a>
                    </div>
                  </div>
                  <div class="tab-pane fade" id="tab-support">
                    <br/>
                    <div class="alert alert-info" role="alert"><i class="fa fa-info-circle" aria-hidden="true"></i> {{ text_support_alert }}</div>
                    <div class="col-md-4 col-md-offset-4 text-center">
                      <div class="form-group">
                        <a href="{{ support }}" target="_blank" id="btn-support" class="btn btn-default btn-lg"><i class="fa fa-paper-plane-o"></i> {{ button_create_request }}</a>
                      </div>
                      <div class="checkbox">
                        <label>
                          <input type="checkbox" id="support-data" value="{{ support_data }}" checked>
                          &nbsp;<span data-toggle="tooltip" title="{{ tooltip_support_data }}">{{ entry_support_data }} <i class="fa fa-question-circle" aria-hidden="true"></i></span>
                        </label>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="modal-general" tabindex="-1" role="dialog" aria-labelledby="" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header"><b></b>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">×</span></button>
      </div>
      <div class="modal-body text-center">
        <img src="../image/no_image.png" />
      </div>
    </div>
  </div>
</div>
<script type="text/javascript"><!--
    $('#orders').load('{{ order_list_action }}');

    var definition_row = {{ definition_row }};
    var definition_count = {{ definition_count }};

    function increaseDefinitionCount() {
        definition_count++;
        definition_row--;
    }

    function addDefinitionRow() {
        if (definition_count) {
            html  = '<tr id="definition-row' + definition_row + '">';
            html += '  <td class="text-left" style="width: 20%;">';
            html += '  <select name="custom_definition[' + definition_row + '][object]" onchange="changeCdObject(' + definition_row + ');" id="select-object' + definition_row + '" class="form-control">';
            html += '  <option value="0" selected="selected">{{ text_user_scope_customer }}</option>';
            html += '  <option value="1">{{ text_event_scope_order }}</option>';
            /** html += '  <option value="2">{{ text_event_scope_product }}</option>'; **/
            html += '  </select>';
            html += '  </td>';
            html += '  <td class="text-right" style="width: 30%;">';
            html += '  <select name="custom_definition[' + definition_row + '][value]" onchange="changeCdValue(' + definition_row + ');" id="select-value' + definition_row + '" class="form-control">';

          {% for customer_column in customer_columns %}
            html += '  <option value="{{ customer_column }}">{{ customer_column }}</option>';
          {% endfor %}

            html += '  </select>';
            html += '  </td>';
            html += '  <td class="text-left">';
            html += '   <input type="text" name="custom_definition[' + definition_row + '][name]" value="customer_id" placeholder="{{ entry_parameter_name }}" id="input-name' + definition_row + '" class="form-control" />';
            html += '  </td>';
            html += '  <td class="text-right"><button type="button" onclick="$(\'#definition-row' + definition_row + '\').remove();definition_row--;$(\'#definition-count\').html(++definition_count);" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
            html += '</tr>';

            $('#custom-definition tbody').append(html);
            $('#definition-count').html(--definition_count);

            definition_row++;
        }
    }

    function changeCdObject(definition_row) {
        $('#select-value' + definition_row).find('option').remove();

        if ($('#select-object' + definition_row).val() == 1) {
            var value_columns = {{ order_columns|json_encode() }};
        } else if ($('#select-object' + definition_row).val() == 2) {
            var value_columns = {{ product_columns|json_encode() }};
        } else {
            var value_columns = {{ customer_columns|json_encode() }};
        }

        $.each(value_columns, function(key, value) {
            $('#select-value' + definition_row).append($('<option></option>').attr('value',value).text(value));
        });

        $('#input-name' + definition_row).val($('#select-value' + definition_row).find(':selected').text());
    }

    function changeCdValue(definition_row) {
        $('#input-name' + definition_row).val($('#select-value' + definition_row).find(':selected').text());
    }
    //--></script>
{{ footer }}