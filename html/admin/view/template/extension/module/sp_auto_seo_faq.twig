			var html  = '<tr id="faq-category-row' + c_faq_row + '">';
			html += '  <td class="text-center">';
			{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <input type="text" name="sp_auto_seo_faq_category_faq[' + c_faq_row + '][faq_data][{{ language.language_id }}][question]" value="" class="form-control" style="display:inline-block;width:80%;" /><br />';
