						<td class="text-center">
							<button type="button" onclick="$('#faq-information-row{{ i_faq_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger">
							<i class="fa fa-minus-circle"></i>
							</button>
						</td>
						</tr>
						{% set i_faq_row = i_faq_row + 1 %}
						{% endfor %}
					</tbody>
					<tfoot>
						<tr>
						<td colspan="3"></td>
						<td class="text-center">
							<button type="button" onclick="addInformationFaq();" data-toggle="tooltip" class="btn btn-primary">
							<i class="fa fa-plus-circle"></i>
							</button>
						</td> 
						</tr>
					</tfoot>
					</table>
				</div>
			</div>
			<script type="text/javascript">
			var i_faq_row = {{ i_faq_row }};
			function addInformationFaq() { 
			var html  = '<tr id="faq-information-row' + i_faq_row + '">';
			html += '  <td class="text-center">';
			{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <input type="text" name="sp_auto_seo_faq_information_faq[' + i_faq_row + '][faq_data][{{ language.language_id }}][question]" value="" class="form-control" style="display:inline-block;width:80%;" /><br />';
			{% endfor %}
			html += '</td>';
			html += '  <td class="text-center">';
			{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <textarea rows="3" name="sp_auto_seo_faq_information_faq[' + i_faq_row + '][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;"></textarea><br />';
			{% endfor %}
			html += '</td>';
			html += '  <td class="text-center" style="width:10%"><input type="text" name="sp_auto_seo_faq_information_faq[' + i_faq_row + '][sort_order]" value="" class="form-control" /></td>';
			html += '  <td class="text-center"><button type="button" onclick="$(\'#faq-information-row' + i_faq_row + '\').remove();" data-toggle="tooltip" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
			html += '</tr>';
			
			$('#information-faq tbody').append(html);
