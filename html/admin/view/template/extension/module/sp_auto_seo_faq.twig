			</script>
			<div class="tab-pane" id="tab-auto-category">
				<fieldset>
				<legend>{{ text_auto_category_help }}</legend>
				{% for language in languages %}
					<div class="form-group">
						<label class="col-sm-2 control-label">{{ entry_category_title }} ({{ language['name'] }} <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/>)</label>
						<div class="col-sm-10">
						<input type="text" name="sp_auto_seo_faq_category_title[{{ language['language_id'] }}]" placeholder="{{ entry_title }}" value="{{ sp_auto_seo_faq_category_title[language['language_id']] ? sp_auto_seo_faq_category_title[language['language_id']] }}" class="form-control" />
						</div>
					</div>
				{% endfor %}
				<legend>{{ text_latest }}</legend>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_status }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_latest_status" {% if sp_auto_seo_faq_latest_status %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_limit }}</label>
						<div class="col-sm-10">
							<input type="text" name="sp_auto_seo_faq_latest_limit" value="{% if sp_auto_seo_faq_latest_limit %}{{ sp_auto_seo_faq_latest_limit }}{% else %}10{% endif %}" class="form-control" />
						</div>
				</div>
				{% for language in languages %}
					<div class="form-group">
						<label class="col-sm-2 control-label">{{ entry_title }} ({{ language['name'] }} <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/>)</label>
						<div class="col-sm-10">
						<input type="text" name="sp_auto_seo_faq_latest_title[{{ language['language_id'] }}]" placeholder="{{ entry_title }}" value="{{ sp_auto_seo_faq_latest_title[language['language_id']] ? sp_auto_seo_faq_latest_title[language['language_id']] }}" class="form-control" />
						</div>
					</div>
				{% endfor %}
				</fieldset>
				<fieldset>
				<legend>{{ text_special }}</legend>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_status }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_special_status" {% if sp_auto_seo_faq_special_status %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
