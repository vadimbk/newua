{{ header }}{{ column_left }}
<div id="content">
{% if not message %}
<div class="page-header"><div class="container-fluid"><div class="pull-right"><button type="submit" form="form-sp_auto_seo_faq" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button><a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div><h1>{{ heading_title }}</h1><ul class="breadcrumb">{% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}</ul></div></div>
	<div class="container-fluid">
	{% if error_warning %}<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>{% endif %}
	<div class="panel panel-default">
	<div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3></div>
	<div class="panel-body">
		<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-sp_auto_seo_faq" class="form-horizontal">
			<ul class="nav nav-tabs">
				<li class="active"><a href="#tab-settings" data-toggle="tab"><i class="fa fa-cog"></i> {{ text_settings }}</a></li>
				<li><a href="#tab-auto-home" data-toggle="tab"><i class="fa fa-rocket"></i> {{ text_auto_home }}</a></li>
				<li><a href="#tab-auto-category" data-toggle="tab"><i class="fa fa-rocket"></i> {{ text_auto_category }}</a></li>
				<li><a href="#tab-auto-manufacturer" data-toggle="tab"><i class="fa fa-rocket"></i> {{ text_auto_manufacturer }}</a></li>
				<li><a href="#tab-auto-product" data-toggle="tab"><i class="fa fa-rocket"></i> {{ text_auto_product }}</a></li>
				<li><a href="#tab-auto-information" data-toggle="tab"><i class="fa fa-rocket"></i> {{ text_auto_information }}</a></li>
				<li><a href="#tab-help" data-toggle="tab"><i class="fa fa-life-ring"></i> {{ text_help }}</a></li>
			</ul>
			<div class="tab-content">
				<div class="tab-pane active" id="tab-settings">
				<div class="form-group"><label class="col-sm-2 control-label"></label><div class="col-sm-10"> {{ text_documentation }}</div></div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_status }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_status" {% if sp_auto_seo_faq_status %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_type }}</label>
					<div class="col-sm-10">
						<select name="sp_auto_seo_faq_type" class="form-control">
							{% for type in sp_auto_seo_faq_types %}
							{% if type.id == sp_auto_seo_faq_type %}
							<option value="{{ type.id }}" selected="selected">{{ type.desc }}</option>
							{% else %}
							<option value="{{ type.id }}">{{ type.desc }}</option>
							{% endif %}
							{% endfor %}
						</select>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ text_cache_enable }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_cache_status" {% if sp_auto_seo_faq_cache_status %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ text_expand }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_expand" {% if sp_auto_seo_faq_expand %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ text_not_first_page }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_not_first_page" {% if sp_auto_seo_faq_not_first_page %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ text_only_stock }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_only_stock" {% if sp_auto_seo_faq_only_stock %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
			</div>
			<div class="tab-pane" id="tab-auto-product">
				<legend>{{ text_auto_product_help }}</legend>
				{% for language in languages %}
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_product_title }} ({{ language.name }} <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/>)</label>
					<div class="col-sm-10">
					<input type="text" name="sp_auto_seo_faq_product_title[{{ language.language_id }}]" placeholder="{{ entry_product_title }}" value="{{ sp_auto_seo_faq_product_title[language.language_id] is defined ? sp_auto_seo_faq_product_title[language.language_id] : '' }}" class="form-control" />
					</div>
				</div>
				{% endfor %}
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_show_in_product }}</label>
					<div class="col-sm-10">
						<label class="switch"><input type="checkbox" name="sp_auto_seo_faq_show_in_product" {% if sp_auto_seo_faq_show_in_product %}checked{% endif %} >
						<span class="slider round"></span>
						</label>
					</div>
				</div>
				<legend>{{ text_auto_product_all_faq }}</legend>
				<div class="table-responsive">
				<table id="product-faq" class="table table-striped table-bordered table-hover">
					<thead>
					<tr> 
						<td class="text-center">{{ column_question }}</td>
						<td class="text-center">{{ column_faq }}</td>
						<td class="text-center" style="width:10%">{{ column_sort_order }}</td>
						<td class="text-center" style="width:10%"></td>
					</tr>
					</thead>
					<tbody>
					{% set p_faq_row = 0 %}
					{% for faq in product_faq %}
					<tr id="faq-product-row{{ p_faq_row }}">
						<td class="text-center">
						{% for language in languages %}
							<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
							<input type="text" name="sp_auto_seo_faq_product_faq[{{ p_faq_row }}][faq_data][{{ language.language_id }}][question]" value="{{ faq.faq_data[language.language_id].question is defined ? faq.faq_data[language.language_id].question : '' }}" class="form-control" style="display:inline-block;width:80%;" /><br />
						{% endfor %}
						</td>
						<td class="text-center">
						{% for language in languages %}
							<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
							<textarea rows="3" name="sp_auto_seo_faq_product_faq[{{ p_faq_row }}][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;">{{ faq.faq_data[language.language_id].answer is defined ? faq.faq_data[language.language_id].answer }}</textarea><br />
						{% endfor %} 
						</td>
						<td class="text-center">
						<input type="text" name="sp_auto_seo_faq_product_faq[{{ p_faq_row }}][sort_order]" value="{{ faq.sort_order }}" class="form-control" />
						</td>
						<td class="text-center">
						<button type="button" onclick="$('#faq-product-row{{ p_faq_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger">
							<i class="fa fa-minus-circle"></i>
						</button>
						</td>
					</tr>
					{% set p_faq_row = p_faq_row + 1 %}
					{% endfor %}
					</tbody>
					<tfoot>
					<tr>
						<td colspan="3"></td>
						<td class="text-center">
						<button type="button" onclick="addProductFaq();" data-toggle="tooltip" class="btn btn-primary">
							<i class="fa fa-plus-circle"></i>
						</button>
						</td>
					</tr>
					</tfoot>
					</table>
				</div>
			</div>
			<script type="text/javascript">
			var p_faq_row = {{ p_faq_row }};
			function addProductFaq() {
			var html  = '<tr id="faq-product-row' + p_faq_row + '">';
			html += '  <td class="text-center">';
			{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <input type="text" name="sp_auto_seo_faq_product_faq[' + p_faq_row + '][faq_data][{{ language.language_id }}][question]" value="" class="form-control" style="display:inline-block;width:80%;" /><br />';
			{% endfor %}
			html += '</td>';
			html += '  <td class="text-center">';
			{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <textarea rows="3" name="sp_auto_seo_faq_product_faq[' + p_faq_row + '][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;"></textarea><br />';
			{% endfor %}
			html += '</td>';
			html += '  <td class="text-center" style="width:10%"><input type="text" name="sp_auto_seo_faq_product_faq[' + p_faq_row + '][sort_order]" value="" class="form-control" /></td>';
			html += '  <td class="text-center"><button type="button" onclick="$(\'#faq-product-row' + p_faq_row + '\').remove();" data-toggle="tooltip" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
			html += '</tr>';
			
			$('#product-faq tbody').append(html);
			p_faq_row++;
			}
			</script>
			<div class="tab-pane" id="tab-auto-home">
				<legend>{{ text_auto_home_help }}</legend>
				{% for language in languages %}
				<div class="form-group">
					<label class="col-sm-2 control-label">{{ entry_home_title }} ({{ language.name }} <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/>)</label>
					<div class="col-sm-10">
						<input type="text" name="sp_auto_seo_faq_home_title[{{ language.language_id }}]" placeholder="{{ entry_home_title }}" value="{{ sp_auto_seo_faq_home_title[language.language_id] is defined ? sp_auto_seo_faq_home_title[language.language_id] : '' }}" class="form-control" />
					</div>
				</div>
				{% endfor %}
				<div class="table-responsive">
					<table id="home-faq" class="table table-striped table-bordered table-hover">
						<thead>
							<tr>
								<td class="text-center">{{ column_question }}</td>
								<td class="text-center">{{ column_faq }}</td>
								<td class="text-center" style="width:10%">{{ column_sort_order }}</td>
								<td class="text-center" style="width:10%"></td>
							</tr>
						</thead>
						<tbody>
							{% set h_faq_row = 0 %}
							{% for faq in home_faq %}
							<tr id="faq-home-row{{ h_faq_row }}">
								<td class="text-center">
								{% for language in languages %}
								<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
								<input type="text" name="sp_auto_seo_faq_home_faq[{{ h_faq_row }}][faq_data][{{ language.language_id }}][question]" value="{{ faq.faq_data[language.language_id].question is defined ? faq.faq_data[language.language_id].question : '' }}" class="form-control" style="display:inline-block;width:80%;" /><br>
								{% endfor %}
								</td>
								<td class="text-center">
								{% for language in languages %}
								<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
								<textarea rows="3" name="sp_auto_seo_faq_home_faq[{{ h_faq_row }}][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;">{{ faq.faq_data[language.language_id].answer is defined ? faq.faq_data[language.language_id].answer : '' }}</textarea><br>
								{% endfor %}
								</td>
								<td class="text-center"><input type="text" name="sp_auto_seo_faq_home_faq[{{ h_faq_row }}][sort_order]" value="{{ faq.sort_order }}" class="form-control" /></td>
								<td class="text-center"><button type="button" onclick="$('#faq-home-row{{ h_faq_row }}').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
							</tr>
							{% set h_faq_row = h_faq_row + 1 %}
							{% endfor %}
						</tbody>
						<tfoot>
							<tr>
								<td colspan="3"></td>
								<td class="text-center"><button type="button" onclick="addHomeFaq();" data-toggle="tooltip" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
							</tr>
						</tfoot>
					</table>
				</div>
			</div>
			<script type="text/javascript">
			let h_faq_row = {{ h_faq_row }};
			function addHomeFaq() {
				let html = '';
				html += '<tr id="faq-home-row' + h_faq_row + '">';
				html += '  <td class="text-center">';
				{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <input type="text" name="sp_auto_seo_faq_home_faq[' + h_faq_row + '][faq_data][{{ language.language_id }}][question]" value="" class="form-control" style="display:inline-block;width:80%;" /><br>';
				{% endfor %}
				html += '  </td>';
				html += '  <td class="text-center">';
				{% for language in languages %}
				html += ' <img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />';
				html += ' <textarea rows="3" name="sp_auto_seo_faq_home_faq[' + h_faq_row + '][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;"></textarea><br>';
				{% endfor %}
				html += '  </td>';
				html += '  <td class="text-center" style="width:10%"><input type="text" name="sp_auto_seo_faq_home_faq[' + h_faq_row + '][sort_order]" value="" class="form-control" /></td>';
				html += '  <td class="text-center"><button type="button" onclick="$(\'#faq-home-row' + h_faq_row + '\').remove();" data-toggle="tooltip" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
				html += '</tr>';
			
				$('#home-faq tbody').append(html);
			
				h_faq_row++;
			}
			</script>
			<div class="tab-pane" id="tab-auto-information">
				<legend>{{ text_auto_information_help }}</legend>
				{% for language in languages %}
				<div class="form-group">
				<label class="col-sm-2 control-label">{{ entry_information_title }} ({{ language['name'] }} <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"/>)</label>
				<div class="col-sm-10">
					<input type="text" name="sp_auto_seo_faq_information_title[{{ language['language_id'] }}]" placeholder="{{ entry_title }}" value="{{ sp_auto_seo_faq_information_title[language['language_id']] ? sp_auto_seo_faq_information_title[language['language_id']] }}" class="form-control" />
				</div>
				</div>
				{% endfor %}
				<legend>{{ text_auto_information_all_faq }}</legend>
				<div class="table-responsive">
					<table id="information-faq" class="table table-striped table-bordered table-hover">
					<thead>
						<tr> 
						<td class="text-center">{{ column_question }}</td>
						<td class="text-center">{{ column_faq }}</td>
						<td class="text-center" style="width:10%">{{ column_sort_order }}</td>
						<td class="text-center" style="width:10%"></td>
						</tr>
					</thead>
					<tbody>
						{% set i_faq_row = 0 %}
						{% for faq in information_faq %}
						<tr id="faq-information-row{{ i_faq_row }}">
						<td class="text-center">
							{% for language in languages %}
							<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
							<input type="text" name="sp_auto_seo_faq_information_faq[{{ i_faq_row }}][faq_data][{{ language.language_id }}][question]" value="{{ faq.faq_data[language.language_id].question is defined ? faq.faq_data[language.language_id].question : '' }}" class="form-control" style="display:inline-block;width:80%;" /><br />
							{% endfor %}
						</td>
						<td class="text-center">
							{% for language in languages %}
							<img src="language/{{ language.code }}/{{ language.code }}.png" style="display:inline-block;" />
							<textarea rows="3" name="sp_auto_seo_faq_information_faq[{{ i_faq_row }}][faq_data][{{ language.language_id }}][answer]" class="form-control" style="display:inline-block;width:80%;">{{ faq.faq_data[language.language_id].answer is defined ? faq.faq_data[language.language_id].answer }}</textarea><br />
							{% endfor %} 
						</td>
						<td class="text-center">
							<input type="text" name="sp_auto_seo_faq_information_faq[{{ i_faq_row }}][sort_order]" value="{{ faq.sort_order }}" class="form-control" />
