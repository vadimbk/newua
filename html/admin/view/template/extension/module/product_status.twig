{{ header }} 
{{ column_left }} 

<div id="content">
	
<style>
/* Text statuses */
.text {
  text-align: center;
  padding: 5px 15px 4px;
  border-radius: 2px;
  display: block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  white-space: nowrap;
  cursor: default;
  height: fit-content;
  width: fit-content;  
}

.text.oval {
  border-radius: 20px;
}

.text.circle {  
  width: 50px;
  height: 50px;
  text-align: center;
  padding: 11px 0 0;
  font-size: 15px;
  line-height: 25px;
  -webkit-border-radius: 25px;
  -moz-border-radius: 25px;
  border-radius: 25px;
}

.text.circle_corner {  
  width: 50px;
  height: 50px;
  text-align: center;
  padding: 11px 0 0;
  font-size: 15px;
  line-height: 25px;
  -webkit-border-radius: 25px 0 25px 25px;
  -moz-border-radius: 25px 0 25px 25px;
  border-radius: 25px 0 25px 25px;
}
.text.my_custom_type1 {
  padding: 4px 15px 5px;
  font-size: 15px;
  text-transform: none;
}
</style>
  
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %} 
        <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
        {% endfor %} 
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if (error_warning) %} 
    <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }} 
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %} 
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
          <ul class="nav nav-tabs">
            <li class="active"><a href="#tab-statuses" data-toggle="tab">{{ tab_statuses }}</a></li>
            <li><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
            <li><a href="#tab-support" data-toggle="tab">{{ tab_support }}</a></li>
          </ul>
          <div class="tab-content">
            <div class="tab-pane active" id="tab-statuses">
							
              <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-delete">
                
                <div class="pull-right">
                  <a href="{{ insert }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
                  <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-delete').submit() : false;"><i class="fa fa-trash-o"></i></button>
                </div>
                <br />
                <br />
                <br />
              
                <table id="statuses" class="table table-striped table-bordered table-hover">  
                  <thead>
                    <tr>
                      <td width="1" style="text-align: center;"><input type="checkbox" onclick="$('input[name*=\'selected\']').attr('checked', this.checked);" /></td>
                      <td class="left">{{ status_image }}</td>                            
                      <td class="left">{{ status_name }}</td>              
                      <td class="left">{{ status_url }}</td>
                      <td class="left">{{ status_display }}</td>
                      <td class="left">{{ sort_order }}</td>
                      <td class="left">{{ status_action }}</td>  
                    </tr>
                  </thead>
                  <tbody>

                  {% if (statuses) %} 
                  {% for status in statuses %} 
                  <tr>
                    <td style="text-align: center;">
                      <input type="checkbox" name="selected[]" value="{{ status['status_id'] }}" class="form-control"/>
                    </td>
                    <td class="left">
										{% if (status['type'] == 'image') %}	
											<img src="{{ status['thumb'] }}" />
										{% else %}	
											<div class="{{ status['type'] == 'text' ? "text " ~ status['text_type'] : "" }} " style="{{ status['type'] == 'text' and status['font_color'] is not empty ? " color:" ~ status['font_color'] ~ ";" : "" }}{{ status['type'] == 'text' and status['background_color'] is not empty ? " background-color:" ~ status['background_color'] ~ ";" : "" }}{{ status['type'] == 'text' and status['border_color'] is not empty ? " border: 2px solid " ~ status['border_color'] ~ ";" : "" }}">
	                      
												{{ status['name'] }} 
												
											</div>
	                  {% endif %}	
										</td>                    
                    <td class="left">{{ status['name'] }}</td>
                    <td class="left"><a href="{{ status['url'] }}">{{ status['url'] }}</a></td>
                    <td class="left">{{ attribute(_context, 'status_display_' ~ status['display']) is defined ? attribute(_context, 'status_display_' ~ status['display']) : '' }}</td>                    
                    <td class="left">{{ status['sort_order'] }}</td>
                    <td class="left">{% for action in status['action'] %} 
                      <a href="{{ action['href'] }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a>
                      {% endfor %}</td>
                  </tr>
                  {% endfor %} 
                  {% else %} 
                  <tr>
                    <td class="center" colspan="7">{{ text_no_results }}</td>
                  </tr>
                  {% endif %} 

                  </tbody>
                </table>

                <div class="pagination">  
                  {{ pagination }} 
                </div>  

              </form>  

							<input type="hidden" name="product_status_module[0][product_status]" value="1" class="form-control"/>
              
            </div>

            <div class="tab-pane" id="tab-general">
              <form action="{{ action_settings }}" method="post" enctype="multipart/form-data" id="form-settings">
                <br />
                <div class="pull-right">
                <button type="submit" form="form-settings" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                </div>
                <br />
                <br />
                <br />

                <table id="general" class="table table-striped table-bordered table-hover">
                  <tr>
                    <td class="left">{{ entry_status }}</td>
                    <td>
                      <select name="module_product_status_status" class="form-control">
                      {% if (options['status']) %}
                        <option value="1" selected="selected">{{ text_enabled }}</option>
                        <option value="0">{{ text_disabled }}</option>
                      {% else %}
                        <option value="1">{{ text_enabled }}</option>
                        <option value="0" selected="selected">{{ text_disabled }}</option>
                      {% endif %}
                      </select>
                    </td>
                  </tr>
                  
                </table>
                <br />

                <table id="general" class="table table-striped table-bordered table-hover">
                  <thead>
                    <tr>
                      <td class="left"></td>
                      <td class="left">{{ text_product }}</td>
                      <td class="left">{{ text_category }}</td>
                    </tr>								  
                  </thead>
                  <tbody >
                    <tr>
                      <td class="left">{{ text_image_width }}<br />{{ text_image_width_help }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[product][image_width]" value="{{ options['product']['image_width'] is defined ? options['product']['image_width'] : '0' }}" class="form-control">
                      </td>
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[category][image_width]" value="{{ options['category']['image_width'] is defined ? options['category']['image_width'] : '0' }}" class="form-control">
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ text_image_height }}<br />{{ text_image_height_help }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[product][image_height]" value="{{ options['product']['image_height'] is defined ? options['product']['image_height'] : '0' }}" class="form-control">
                      </td>
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[category][image_height]" value="{{ options['category']['image_height'] is defined ? options['category']['image_height'] : '0' }}" class="form-control">
                      </td>
                    </tr>

                    <tr>
                      <td class="left">{{ text_sticker_image_width }}<br />{{ text_sticker_image_width_help }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[product_sticker][image_width]" value="{{ options['product_sticker']['image_width'] is defined ? options['product_sticker']['image_width'] : '0' }}" class="form-control">
                      </td>
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[category_sticker][image_width]" value="{{ options['category_sticker']['image_width'] is defined ? options['category_sticker']['image_width'] : '0' }}" class="form-control">
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ text_sticker_image_height }}<br />{{ text_sticker_image_height_help }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[product_sticker][image_height]" value="{{ options['product_sticker']['image_height'] is defined ? options['product_sticker']['image_height'] : '0' }}" class="form-control">
                      </td>
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[category_sticker][image_height]" value="{{ options['category_sticker']['image_height'] is defined ? options['category_sticker']['image_height'] : '0' }}" class="form-control">
                      </td>
                    </tr>

                    <tr>
                      <td class="left">{{ text_name_display }}</td>              
                      <td style="text-align: left;">
                        <select name="module_product_status_options[product][name_display]" class="form-control">
                          <option value="0" {{ options['product']['name_display'] is defined and not options['product']['name_display'] ? 'selected="selected"' : '' }}>{{ text_name_display_disable }}</option>
                          <option value="next" {{ options['product']['name_display'] is defined and options['product']['name_display'] == 'next' ? 'selected="selected"' : '' }}>{{ text_name_display_next }}</option>
                          <option value="tip" {{ options['product']['name_display'] is defined and options['product']['name_display'] == 'tip' ? 'selected="selected"' : '' }}>{{ text_name_display_tip }}</option>
                        </select>					
                      </td>
                      <td style="text-align: left;">
                        <select name="module_product_status_options[category][name_display]" class="form-control">
                          <option value="0" {{ options['category']['name_display'] is defined and not options['category']['name_display'] ? 'selected="selected"' : '' }}>{{ text_name_display_disable }}</option>
                          <option value="next" {{ options['category']['name_display'] is defined and options['category']['name_display'] == 'next' ? 'selected="selected"' : '' }}>{{ text_name_display_next }}</option>
                          <option value="tip" {{ options['category']['name_display'] is defined and options['category']['name_display'] == 'tip' ? 'selected="selected"' : '' }}>{{ text_name_display_tip }}</option>
                        </select>					
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ text_status_display }}</td>              
                      <td style="text-align: left;">
                        <select name="module_product_status_options[product][status_display]" class="form-control">
                          <option value="0" {{ options['product']['status_display'] is defined and not options['product']['status_display'] ? 'selected="selected"' : '' }}>{{ text_status_display_disable }}</option>
                          <option value="inline" {{ options['product']['status_display'] is defined and options['product']['status_display'] == 'inline' ? 'selected="selected"' : '' }}>{{ text_status_display_inline }}</option>
                          <option value="new_line" {{ options['product']['status_display'] is defined and options['product']['status_display'] == 'new_line' ? 'selected="selected"' : '' }}>{{ text_status_display_new_line }}</option>
                        </select>					
                      </td>
                      <td style="text-align: left;">
                        <select name="module_product_status_options[category][status_display]" class="form-control">
                          <option value="0" {{ options['category']['status_display'] is defined and not options['category']['status_display'] ? 'selected="selected"' : '' }}>{{ text_status_display_disable }}</option>
                          <option value="inline" {{ options['category']['status_display'] is defined and options['category']['status_display'] == 'inline' ? 'selected="selected"' : '' }}>{{ text_status_display_inline }}</option>
                          <option value="new_line" {{ options['category']['status_display'] is defined and options['category']['status_display'] == 'new_line' ? 'selected="selected"' : '' }}>{{ text_status_display_new_line }}</option>
                        </select>					
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ text_auto_display }}</td>              
                      <td style="text-align: left;">
                        <select name="module_product_status_options[product][auto_display]" class="form-control">
                          <option value="0" {{ options['product']['auto_display'] is defined and not options['product']['auto_display'] ? 'selected="selected"' : '' }}>{{ text_auto_display_disable }}</option>
                          <option value="1" {{ options['product']['auto_display'] is defined and options['product']['auto_display'] ? 'selected="selected"' : '' }}>{{ text_auto_display_enable }}</option>                    
                        </select>					
                      </td>
                      <td style="text-align: left;">
                        <select name="module_product_status_options[category][auto_display]" class="form-control">
                          <option value="0" {{ options['category']['auto_display'] is defined and not options['category']['auto_display'] ? 'selected="selected"' : '' }}>{{ text_auto_display_disable }}</option>
                          <option value="1" {{ options['category']['auto_display'] is defined and options['category']['auto_display'] ? 'selected="selected"' : '' }}>{{ text_auto_display_enable }}</option>                    
                        </select>					
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ text_sticker_display }}</td>              
                      <td style="text-align: left;">
                        <select name="module_product_status_options[product][sticker_display]" class="form-control">
                          <option value="0" {{ options['product']['sticker_display'] is defined and not options['product']['sticker_display'] ? 'selected="selected"' : '' }}>{{ text_sticker_display_disable }}</option>
                          <option value="1" {{ options['product']['sticker_display'] is defined and options['product']['sticker_display'] ? 'selected="selected"' : '' }}>{{ text_sticker_display_enable }}</option>                    
                        </select>					
                      </td>
                      <td style="text-align: left;">
                        <select name="module_product_status_options[category][sticker_display]" class="form-control">
                          <option value="0" {{ options['category']['sticker_display'] is defined and not options['category']['sticker_display'] ? 'selected="selected"' : '' }}>{{ text_sticker_display_disable }}</option>
                          <option value="1" {{ options['category']['sticker_display'] is defined and options['category']['sticker_display'] ? 'selected="selected"' : '' }}>{{ text_sticker_display_enable }}</option>                    
                        </select>					
                      </td>
                    </tr> 
                  </tbody>
                </table>

                <br />
                <table id="general" class="table table-striped table-bordered table-hover">
                  <tbody >
                    <tr>
                      <td class="left">{{ status_text_custom_types }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[status_text_custom_types]" value="{{ options['status_text_custom_types'] is defined ? options['status_text_custom_types'] : '' }}" class="form-control">
                      </td>
                    </tr>                    
                    <tr>
                      <td class="left">{{ status_new_hours }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[status_new_hours]" value="{{ options['status_new_hours'] is defined ? options['status_new_hours'] : '0' }}" class="form-control">
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ status_bestseller_total }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[status_bestseller_total]" value="{{ options['status_bestseller_total'] is defined ? options['status_bestseller_total'] : '0' }}" class="form-control">
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ status_popular_total }}</td>              
                      <td style="text-align: left;">
                        <input type="text" name="module_product_status_options[status_popular_total]" value="{{ options['status_popular_total'] is defined ? options['status_popular_total'] : '0' }}" class="form-control">
                      </td>
                    </tr>
                    <tr>
                      <td class="left">{{ cache_results }}</td>              
                      <td style="text-align: left;">
                        <input type="checkbox" name="module_product_status_options[cache]" value="1" {{ options['cache'] is defined and options['cache'] ? 'checked="checked"' : '' }}" class="form-control">
                      </td>
                    </tr>
                  </tbody>
                </table>

              </form>

            </div>
							
						<div class="tab-pane" id="tab-support">
              {{ support_text }} 
            </div>
            
					</div>
      </div>
    </div>
  </div>
  
