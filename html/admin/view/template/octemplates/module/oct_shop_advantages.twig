<script>
function fontIcons(icone_id, input_id) {
	$.ajax({
		url: 'index.php?route=extension/theme/oct_ultrastore/getIcons&user_token={{ user_token }}&icone_id=' + icone_id + '&input_id=' + input_id,
		type: 'get',
		dataType: 'html',
		cache: false,
		success: function(data) {
			html  = '<div id="modal-icons" class="modal">';
			html += '  <div class="modal-dialog" style="width:55%;">';
			html += '    <div class="modal-content">';
			html += '      <div class="modal-header">';
			html += '        <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>';
			html += '        <h4 class="modal-title">Font Awesome Icons</h4>';
			html += '      </div>';
			html += '      <div class="modal-body">' + data + '</div>';
			html += '    </div>';
			html += '  </div>';
			html += '</div>';
			
			$('body').append(html);
			
			$('#modal-icons').modal('show');
		}
	});
}
</script>
