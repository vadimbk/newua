											<input
												type="text"
												name="heading_block1[{{ language.code }}]"
												value="{{ heading_block1[language.code] is not empty ? heading_block1[language.code] : '' }}"
												class="form-control"
												/>
											{% if (error_heading_block1[language.code] is defined) %} 
											<div class="text-danger">
												<script>
													usNotify('warning', '{{ error_heading_block1[language.code] }}');
												</script>
											</div>
											{% endif %} 
										</div>
										{% endfor %} 
									</div>
								</div>
							</div>
