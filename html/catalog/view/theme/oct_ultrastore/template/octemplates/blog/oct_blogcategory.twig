{{ header }}
<div class="container">
	{{ oct_breadcrumbs }}
	<div class="row">
		<div class="col-12">
			<h1 class="us-main-shop-title">{{ heading_title }}</h1>
		</div>
	</div>
	<div class="content-top-box">{{ content_top }}</div>
	<div class="row us-blog-category-row">
		{{ column_left }}
		{% if column_left and column_right %}
		{% set class = 'col-md-6' %}
		{% elseif column_left or column_right %}
		{% set class = 'col-md-9' %}
		{% else %}
		{% set class = 'col-md-12' %}
		{% endif %}
		<div class="{{ class }} us-blog-category-content">
			{% if blog_categories %}
				<div class="blog_categories">
				{% for category in blog_categories %}
					<div class="blog-category-item">
						<a href="{{ category.href }}"> {{ category.name }}</a>
					</div>
				{% endfor %}
				</div>
				<div class="clearfix man"></div>
			{% endif %}
			<div class="us-blog-category-cont d-flex flex-wrap justify-content-between">
				{% if articles %}
					{% for article in articles %}
						{% if loop.first %}
							<a href="{{ article.href }}" style="background: url('{{ article.thumb }}') no-repeat center center; background-size: cover" class="us-news-block-banner d-flex flex-column">
								<div class="us-news-banner-info">
									<div class="us-news-stickers-date">
										{{ article.date_added }}
									</div>
									<div class="us-news-block-cont d-flex flex-column justify-content-start">
										<div class="us-news-block-title">
											{{ article.name }}
										</div>
										<div class="us-news-block-text">
											<p>
												{{ article.description }}
											</p>
										</div>
									</div>
								</div>
							</a>
						{% else %}
							<div class="us-news-block d-flex flex-column">
								<div class="us-news-block-photo">
									<div class="us-news-stickers-date">
										{{ article.date_added }}
									</div>
									<a href="{{ article.href }}" title="{{ article.name }}" class="h-100 w-100"><img src="{{ article.thumb }}" class="w-100" alt="{{ article.name }}"></a>
								</div>
								<div class="us-news-block-cont d-flex flex-column justify-content-start h-100">
									<a href="{{ article.href }}" class="us-news-block-title">
										{{ article.name }}
									</a>
									<div class="us-news-block-text">
										<p>
											{{ article.description }}
										</p>
									</div>
								</div>
							</div>
						{% endif %}
					
					{% endfor %}
				{% else %}
				<div class="us-content w-100">
					<p>{{ text_empty }}</p>
					<a href="{{ continue }}" class="us-module-btn mt-3 d-inline-block">{{ button_continue }}</a>
				</div>
				{% endif %}
			</div>
			{% if pagination|striptags %}
			<div class="us-pagination-cont">
				{{ pagination }}
			</div>
			{% endif %}
		</div>
		{{ column_right }}
	</div>
	{{ content_bottom }}
</div>
<style>
.us-main-shop-title{
margin-top: 0px;
margin-bottom: 0px;
}
.blog_categories {
	margin-top: 22px;
	display: flex;
	flex-wrap: wrap;
	gap: 10px;
}
.blog_categories .blog-category-item > a {
		display: inline-block;
		transition: border-color .2s ease;
    padding: 3px 12px;
    border: 1px solid #ccc;
}
.blog_categories .blog-category-item > a:hover {
	border-color: rgb(95, 135, 209);
}

.us-news-block-banner {
	display: block;
	min-height: 300px;
	width: 100%;
	transition: all 0.2s ease;
	overflow: hidden;
	margin: 30px 0;
}
.us-news-block-banner:hover {
	box-shadow: 0px 2px 10px rgba(0, 0, 0, 0.1);
}
.us-news-block-banner .us-news-banner-info .us-news-stickers-date {
	display: inline-block;
	position: relative;
	margin-bottom: 20px;
}
.us-news-block-banner .us-news-block-cont {
	margin: 15px;
	background: #00000073;
  padding: 15px 0;
	max-width: 600px;
}
.us-news-block-banner .us-news-block-title {
	color: #fff;
	font-size: 1.5em;
}
.us-news-block-banner .us-news-block-text {
	color: #fff;
}
@media (max-width: 991px) {
	.us-news-block-banner .us-news-block-cont {
		max-width: 100%;
	}
}
@media (max-width: 574px) {
	.us-news-block-banner .us-news-block-title {
	    font-size: 1.2em;
	    line-height: 1.3;
	}
}
</style>
{{ footer }}