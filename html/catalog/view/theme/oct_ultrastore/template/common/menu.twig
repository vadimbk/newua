{% if categories %}
	{% if deff is defined and deff %}
	<div id="oct-menu-box" class="col-lg-3 qwe">
	<div  id="oct-ultra-menu-header" class="oct-ultra-menu d-flex align-items-center justify-content-center">
		<span><i class="fas fa-bars"></i> {{ text_category }}</span>
	</div>
	<nav id="oct-menu-dropdown-menu">
		<ul id="oct-menu-ul" class="oct-menu-ul oct-menu-parent-ul list-unstyled">
	{% endif %}
	{% for category in categories %}
		{% if category.children %}
			<li class="oct-menu-li oct-menu-li-main">
				<div class="d-flex align-items-center justify-content-between">
					<a href="{{ category.href }}" class="oct-menu-a"><span class="oct-menu-item-name">{{ category.name }}</span></a>{% if category.children %}<span class="oct-menu-toggle"><i class="fas fa-chevron-right"></i></span>{% endif %}
				</div>
				<div class="oct-menu-child-ul">
					<div class="oct-menu-back"><i class="fas fa-long-arrow-alt-left"></i> {{ category.name }}</div>
					<ul class="oct-menu-ul list-unstyled">
						{% for child in category.children %}
						<li class="oct-menu-li">
							<div class="d-flex align-items-center justify-content-between">
								<a href="{{ child.href }}"><span class="oct-menu-item-name test">{{ child.name }}</span></a>{% if child.children %}<span class="oct-childmenu-toggle"><i class="fas fa-chevron-right"></i></span>{% endif %}
							</div>
							{% if child.children %}
							<div class="oct-menu-child-ul oct-menu-third-child-ul">
								<div class="oct-childmenu-back"><i class="fas fa-long-arrow-alt-left"></i> {{ child.name }}</div>
								<ul class="oct-menu-ul list-unstyled">
									{% for ch in child.children %}
									<li class="oct-menu-li"><a href="{{ ch.href }}"><span class="oct-menu-item-name">{{ ch.name }}</span></a></li>
									{% endfor %}
								</ul>
							</div>
							{% endif %}
						</li>
						{% endfor %}
					</ul>
				</div>
			</li>
		{% else %}
			<li class="oct-menu-li oct-menu-li-else"><a href="{{ category.href }}" class="oct-menu-a"><span class="oct-menu-item-name">{{ category.name }}</span></a></li>
		{% endif %}
	{% endfor %}
	{% if oct_all_categories is defined and oct_all_categories and deff is not defined %}
		<li class="oct-menu-li"><a href="{{ oct_all_categories }}" class="oct-menu-a"><span class="oct-menu-item-name">{{ entry_oct_all_categories }}</span></a></li>
	{% endif %}
	{% if deff is defined and deff %}
			</ul>
		</nav>
	</div>
	</div>
	{% endif %}
{% endif %}
