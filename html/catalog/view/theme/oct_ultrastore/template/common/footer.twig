<footer>
  <!-- esputnik !-->
    {% if email  %}
        <span id="EsMail" style="display:none">{{ email }}</span>
    {% endif %}
    {% if telephone %}
        <span id="EsPhone" style="display:none">{{ telephone }}</span>
    {% endif %}
    <!-- esputnik !-->
    <div class="container footer-sub">
        <div class="row">
            {% if informations %}
            <div class="col-lg-3 col-md-6 us-footer-box">
                <div class="us-footer-title">{{ text_information }}<i class="fas fa-chevron-down d-md-none"></i></div>
			{{ footer_links }}
            </div>
            {% endif %}
            {% if categories is defined and categories %}
            <div class="col-lg-3 col-md-6 us-footer-box">
                <div class="us-footer-title">{{ oct_footer_category }}<i class="fas fa-chevron-down d-md-none"></i></div>
                <ul class="us-footer-list  list-unstyled mb-0">
                	{% for category in categories %}
                    <li class="us-footer-item"><a href="{{ category.href }}" class="us-footer-link">{{ category.name }}</a></li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
            <div class="col-lg-3 col-md-6 us-footer-box us-footer-shedule-box">
                <div class="us-footer-title">{{ oct_working_hours }}<i class="fas fa-chevron-down d-md-none"></i></div>
                <div class="us-footer-list">
                	{% if oct_contact_opens is defined and oct_contact_opens is not empty %}
                    <div class="us-footer-shedule d-flex align-items-center">
                        <div class="us-footer-shedule-icon">
                            <img src="catalog/view/theme/oct_ultrastore/img/footer-shedule-icon.svg" alt="" />
                        </div>
                        <ul class="us-footer-shedule-text list-unstyled mb-0">
                        	{% for oct_contact_open in oct_contact_opens %}
                            <li class="us-footer-shedule-text-item">{{ oct_contact_open }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                    {% endif %}
                    {% if oct_ultrastore_data.socials is defined and oct_ultrastore_data.socials is not empty %}
                    <div class="us-footer-social">
                        <div class="us-footer-social-text us-footer-text">{{ oct_footer_social_tex }}</div>
                        <ul class="us-footer-social-list d-flex list-unstyled">
                        	{% for social in oct_ultrastore_data.socials %}
                            <li class="us-footer-social-item"><a rel="noindex, nofollow" href="{{ (social.link == "#" or social.link is empty) ? 'javascript:;' : social.link }}" class="us-footer-social-link us-footer-social-link-{{ social.icone|replace({'fa ': "", "fab " : "", "far " : "", "fas " : ""}) }}" target="_blank"><i class="{{ social.icone }}"></i></a></li>
                            {% endfor %}
							<li class="us-footer-contact-item"><a rel="noindex, nofollow" target="_blank" href="https://www.tiktok.com/@radio.shop?_t=8nyqcuTBCzN" class="us-footer-contact-link us-footer-contact-link-tiktok"><i class="tiktok"></i></a></li>               
                        </ul>
                    </div>
                    {% endif %}
                </div>
            </div>
            <div class="col-lg-3 col-md-6 us-footer-box">
                <div class="us-footer-title">{{ oct_footer_contacts }}<i class="fas fa-chevron-down d-md-none"></i></div>
                <div class="us-footer-list us-footer-contact-box">
                	{% if oct_contact_telephones is defined and oct_contact_telephones is not empty %}
                		{% if oct_contact_telephones|length > 1 %}
	                    <a class="btn us-footer-phone-btn top-phone-btn dropdown-toggle d-flex align-items-center" href="tel:{{ oct_contact_telephones[0]|replace({" " : "", "-" : "", "(" : "", ")" : ""}) }}" role="button" id="dropdownMenu5" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">{{ oct_contact_telephones[0] }} <i class="fas fa-chevron-down"></i></a>
	                    <ul class="dropdown-menu header-dropdown-menu" aria-labelledby="dropdownMenu5">
	                    	{% for oct_contact_telephone in oct_contact_telephones %}
	                        <li><a href="tel:{{ oct_contact_telephone|replace({" " : "", "-" : "", "(" : "", ")" : ""}) }}" class="phoneclick"><i class="fas fa-phone-volume"></i> {{ oct_contact_telephone }}</a></li>
	                        {% endfor %}
	                    </ul>
						{% else %}
						<a class="btn us-footer-phone-btn top-phone-btn d-flex align-items-center" href="tel:{{ oct_contact_telephones[0]|replace({" " : "", "-" : "", "(" : "", ")" : ""}) }}" role="button" id="dropdownMenu5">{{ oct_contact_telephones[0] }}</a>
						{% endif %}
                    {% endif %}
                    {% if oct_ultrastore_data.contact_email is defined and oct_ultrastore_data.contact_email %}
                    <a href="mailto:{{ oct_ultrastore_data.contact_email }}" class="us-footer-mail">{{ oct_ultrastore_data.contact_email }}</a>
                    {% endif %}
                    {% if oct_ultrastore_data.contact_address[oct_lang_id] is defined and oct_ultrastore_data.contact_address[oct_lang_id] %}
                    <div class="us-footer-address">{{ oct_ultrastore_data.contact_address[oct_lang_id] }}</div>
                    {% endif %}
                    <ul class="us-footer-contact-list d-flex list-unstyled">
                    	{% if oct_ultrastore_data.contact_skype is defined and oct_ultrastore_data.contact_skype %}
                        <li class="us-footer-contact-item"><a rel="noindex, nofollow" href="skype:{{ oct_ultrastore_data.contact_skype }}?chat" class="us-footer-contact-link us-footer-contact-link-skype"><i class="fab fa-skype"></i></a></li>
                        {% endif %}
                        {% if oct_ultrastore_data.contact_viber is defined and oct_ultrastore_data.contact_viber %}
                        <li class="us-footer-contact-item us-fixed-contact-viber-desktop"><a rel="noindex, nofollow" href="viber://chat?number=+{{ oct_ultrastore_data.contact_viber }}" class="us-footer-contact-link us-footer-contact-link-viber"><i class="fab fa-viber"></i></a></li>
                        <li class="us-footer-contact-item us-fixed-contact-viber-mobile"><a rel="noindex, nofollow" href="viber://add?number={{ oct_ultrastore_data.contact_viber }}" class="us-footer-contact-link us-footer-contact-link-viber"><i class="fab fa-viber"></i></a></li>
                        {% endif %}
                        {% if oct_ultrastore_data.contact_telegram is defined and oct_ultrastore_data.contact_telegram %}
                        <li class="us-footer-contact-item"><a rel="noindex, nofollow" target="_blank" href="https://t.me/{{ oct_ultrastore_data.contact_telegram }}" class="us-footer-contact-link us-footer-contact-link-telegram"><i class="fab fa-telegram"></i></a></li>
                        {% endif %}
                        {% if oct_ultrastore_data.contact_whatsapp is defined and oct_ultrastore_data.contact_whatsapp %}
                        <li class="us-footer-contact-item"><a rel="noindex, nofollow" href="whatsapp://send?phone={{ oct_ultrastore_data.contact_whatsapp }}" class="us-footer-contact-link us-footer-contact-link-whatsapp"><i class="fab fa-whatsapp"></i></a></li>
                        {% endif %}
                        {% if oct_ultrastore_data.contact_messenger is defined and oct_ultrastore_data.contact_messenger %}
                        <li class="us-footer-contact-item"><a rel="noindex, nofollow" href="https://m.me/{{ oct_ultrastore_data.contact_messenger }}" class="us-footer-contact-link us-footer-contact-link-messenger"><i class="fab fa-facebook-messenger"></i></a></li>
                        {% endif %}
						</ul>
                </div>
            </div>
        </div>
        <div class="row row-padding-top">
            <div class="col-lg-12">
                <div class="us-footer-bottom d-flex justify-content-between">
                    <div class="us-footer-bottom-credits col-sm-6"> {{ text_copy }}</div>
					
                	<ul class="us-footer-bottom-payment-list d-flex list-unstyled">
                		{% if oct_ultrastore_data.payments.sber is defined and oct_ultrastore_data.payments.sber %}
						<li class="us-footer-bottom-payment-item sberbank"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.privat24 is defined and oct_ultrastore_data.payments.privat24 %}
						<li class="us-footer-bottom-payment-item privat24"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.ym is defined and oct_ultrastore_data.payments.ym %}
						<li class="us-footer-bottom-payment-item yandex-money"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.wm is defined and oct_ultrastore_data.payments.wm %}
						<li class="us-footer-bottom-payment-item webmoney"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.visa is defined and oct_ultrastore_data.payments.visa %}
						<li class="us-footer-bottom-payment-item visa"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.qw is defined and oct_ultrastore_data.payments.qw %}
						<li class="us-footer-bottom-payment-item qiwi"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.skrill is defined and oct_ultrastore_data.payments.skrill %}
						<li class="us-footer-bottom-payment-item skrill"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.interkassa is defined and oct_ultrastore_data.payments.interkassa %}
						<li class="us-footer-bottom-payment-item interkassa"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.lp is defined and oct_ultrastore_data.payments.lp %}
						<li class="us-footer-bottom-payment-item liqpay"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.pp is defined and oct_ultrastore_data.payments.pp %}
						<li class="us-footer-bottom-payment-item paypal"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.robo is defined and oct_ultrastore_data.payments.robo %}
						<li class="us-footer-bottom-payment-item robokassa"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.mc is defined and oct_ultrastore_data.payments.mc %}
						<li class="us-footer-bottom-payment-item mastercard"></li>
					{% endif %}
					
                    {% if oct_ultrastore_data.payments.maestro is defined and oct_ultrastore_data.payments.maestro %}
						<li class="us-footer-bottom-payment-item maestro"></li>
					{% endif %}
					
					{% for payment_customer in oct_customer_paymets %}
						<li class="us-footer-bottom-payment-item custom-payment"><img src="{{ payment_customer }}" alt=""></li>
					{% endfor %}
			    	</ul>
                </div>
            </div>
        </div>
    </div>
</footer>
