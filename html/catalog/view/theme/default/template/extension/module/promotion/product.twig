<div class="product-promotion {{promotion['special'] is not empty ? 'special' : '' }} {{promotion['discount'] is not empty ? 'discount' : '' }}">

	{% if (promotion['thumb'] is not empty) %} 
		<div class="promotion-image">
			{% if (promotion['gift']['href'] is not empty) %} 
				<a href = "{{ promotion['gift']['href'] }}" title="{{ promotion['gift']['name'] }}">
					<img src="{{ promotion['thumb'] }}" />
				</a>
			{% else %} 
				<img src="{{ promotion['thumb'] }}" />
			{% endif %} 
		</div>
	{% endif %} 

	<h3 class="promotion-name">
		{{ promotion['name'] }} 
	</h3>

	{% if (promotion['gifts_left'] is not empty) %} 
		<div class="gifts-left"> {{ promotion['gifts_left'] }}</div>
	{% endif %} 

	{% if (promotion['options']['product']['timer']['type'] == 'text_period') %} 

		{% if (promotion['text_timer']['text_period'] is not empty) %} 
			<div class="promotion-text-timer" style="{{promotion['options']['product']['timer']['font_size'] is not empty ? 'font-size: ' ~ promotion['options']['product']['timer']['font_size'] ~ 'px' : '' }}">
				<div class="text-timer-text-period">{{ promotion['text_timer']['text_period'] }}</div>
			</div>		
		{% endif %} 

	{% elseif (promotion['options']['product']['timer']['type'] != 'disable' and promotion['active'] and not promotion['date_end_empty']) %} 

		<div class="promotion-timer">
			<div class="timer-title">
				{{ promotion_valid }} 
			</div>
			<div class="timer-counter">
				<div id="counter{{ promotion['promotion_id'] }}"></div>
			</div>
		</div>

		<script>
	    $(document).ready(function () {
	      var date = new Date('{{ promotion['date_end'] }}');
	      //date.setTime(date.getTime() + date.getTimezoneOffset()*60*1000);
	      $('#counter{{ promotion['promotion_id'] }}').timeTo({
	      timeTo: date,
	              displayCaptions: true,
	{% if (promotion['options']['product']['timer']['theme'] == 'black') %} 
		      theme: 'black',
	{% endif %} 
	{% if (promotion['options']['product']['timer']['font_size'] is not empty) %} 
		      fontSize: {{ promotion['options']['product']['timer']['font_size'] }},
	{% endif %} 
	{% if (promotion['options']['product']['timer']['type'] == 'static') %} 
		      start: false,
	{% endif %} 

	      lang: '{{promotion_counter_language is not empty ? promotion_counter_language : 'en' }}'
	    });
	    });
		</script>					  

	{% endif %} 

	<div class="promotion-details">
		<div class="details-title">
			<a data-toggle="modal" href="#promotion-popup{{ promotion['promotion_id'] }}">{{ promotion_about }}&nbsp;▼</a>
		</div>
		{{ promotion['popup'] }}    
	</div>

</div>