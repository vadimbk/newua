{{ header }} 
<div class="container">
  <ul class="breadcrumb">
    {% for breadcrumb in breadcrumbs %} 
    <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
    {% endfor %} 
  </ul>
  <div class="row">{{ column_left }} 
    {% if (column_left and column_right) %} 
    {% set class = 'col-sm-6' %} 
    {% elseif (column_left or column_right) %} 
    {% set class = 'col-sm-9' %} 
    {% else %} 
    {% set class = 'col-sm-12' %} 
    {% endif %} 
    <div id="content" class="{{ class }}">{{ content_top }} 
      <h1>{{ heading_title }}</h1> 
      <form action="" id="form" method="POST">
      {% if (payment_methods) %} 
      <input type="hidden" name="payment_code" value="{{ balance_currency_code }}" /> 
      <div class="form-group">
          <label for="psum">{{ text_balance_sum }}</label>
          <input class="form-control" type="text" id="psum" name="payment_sum" value="" placeholder="{{ entry_balance_sum }}" required="required" /> 
      </div>
      <div class="form-group">
      <p>{{ text_balance_method }}</p>
      {% for payment_method in payment_methods %} 
      <div class="radio">
        <label>
          {% if (code is not defined) %} 
          {% set code = payment_method['code'] %} 
          <input type="radio" name="payment_method" data-item="{{ payment_method['href'] }}" value="{{ payment_method['code'] }}" checked="checked" />
          {% else %} 
          <input type="radio" name="payment_method" data-item="{{ payment_method['href'] }}" value="{{ payment_method['code'] }}" />
          {% endif %} 
          {{ payment_method['name'] }} 
        </label>
      </div>
      {% endfor %} 
      {% endif %} 
      </div>
      <div class="buttons">
        <div class="pull-left">
          <input type="submit" value="{{ button_continue }}" id="button-payment-method" data-loading-text="{{ text_loading }}" class="btn btn-primary" />
        </div>
      </div>
      </form>
      {{ content_bottom }} 
    </div>
    {{ column_right }} 
  </div>
</div>
<script>
  $("form").submit(function(){
    $('#form').attr('action', $('input[name=payment_method]:checked').data('item'));
  });
</script>
{{ footer }}