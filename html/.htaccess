<IfModule Litespeed>
RewriteEngine On


# Serve static files directly (bypass PHP)
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf)$ [NC]
RewriteRule ^(.*)$ - [L]



# Block aggressive bots
RewriteCond %{HTTP_USER_AGENT} Bytespider [NC]
RewriteRule .* - [F,L]

Deny from 199.47.82.18
# Tencent Cloud — distributed bot abuse 2026-05-25
Deny from 43.128.0.0/11
Deny from 43.160.0.0/12
Deny from 49.51.0.0/16
Deny from 119.28.0.0/15
Deny from 124.156.0.0/16
Deny from 150.109.0.0/16
Deny from 162.62.0.0/16
Deny from 170.106.0.0/16

# Allow access for AHRefs

Allow from 54.36.148.0/24
Allow from 54.36.149.0/24
Allow from 195.154.122.0/24
Allow from 195.154.123.0/24
Allow from 195.154.126.0/24
Allow from 195.154.127.0/24
Allow from 51.222.253.0/26



RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

RewriteCond %{HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]


# 1.To use URL Alias you need to be running apache with mod_rewrite enabled.

# 2. In your opencart directory rename htaccess.txt to .htaccess.

# For any support issues please visit: http://www.opencart.com

Options +FollowSymlinks

# Prevent Directoy listing
Options -Indexes

# Prevent Direct Access to files
<FilesMatch "(?i)((\.tpl|.twig|\.ini|\.log|(?<!robots)\.txt))">
 Require all denied
## For apache 2.2 and older, replace "Require all denied" with these two lines :
# Order deny,allow
# Deny from all
</FilesMatch>

# X-Frame-Options
<IfModule mod_headers.c>
	Header always append X-Frame-Options SAMEORIGIN
</IfModule>

<IfModule mod_deflate.c>
# compress text, HTML, JavaScript, CSS, and XML
AddOutputFilterByType DEFLATE text/plain
AddOutputFilterByType DEFLATE text/html
AddOutputFilterByType DEFLATE text/xml
AddOutputFilterByType DEFLATE text/css
AddOutputFilterByType DEFLATE application/xml
AddOutputFilterByType DEFLATE application/xhtml+xml
AddOutputFilterByType DEFLATE application/rss+xml
AddOutputFilterByType DEFLATE application/javascript
AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

Header add Link "</catalog/view/theme/oct_ultrastore/stylesheet/fontawesome-free-5.6.1-web/webfonts/fa-regular-400.woff2>; rel=preload; as=font; type=font/woff2; crossorigin" 
Header add Link "</catalog/view/theme/oct_ultrastore/stylesheet/fontawesome-free-5.6.1-web/webfonts/fa-solid-900.woff2>; rel=preload; as=font; type=font/woff2; crossorigin"

RewriteCond %{HTTP_ACCEPT} "image/webp"
RewriteCond %{REQUEST_FILENAME}.webp -f
RewriteRule ^(.*).(jpg|png|gif) $1.$2.webp [T=image/webp,L]

#### Prevent kill signal
RewriteRule .* - [E=noabort:1]

# SEO URL Settings
RewriteEngine On


# If your opencart installation does not run on the main web folder make sure you folder it does run in ie. / becomes /shop/

RewriteBase /


#Redirect / v konce
RewriteRule ^admin/ - [L]
RewriteCond %{HTTP_HOST} (.*)
RewriteCond %{REQUEST_URI} /$ [NC]
RewriteRule ^(.*)(/)$ $1 [L,R=301]

#Redirect / vseredine
RewriteCond %{THE_REQUEST} \s/+(.*?)/{2,}([^\s]*)
RewriteRule ^ %1/%2 [R=302,L,NE]
RewriteRule (.+)/$ /$1 [L,R=301]

#Redirect page=1
RewriteCond %{QUERY_STRING} ^page=1$
RewriteRule (.*) $1? [L,R=301]

#Redirect %20
RewriteRule ^(.*)\s(.*) /$1$2 [L,R=301]

# Redirect technical blog URL to SEO URL
RewriteCond %{QUERY_STRING} ^route=octemplates/blog/oct_bloglatest$ [NC]
RewriteCond %{REQUEST_URI} ^/uk/index\.php$ [NC]
RewriteRule ^uk/index\.php$ /uk/blog? [R=301,L]

RewriteCond %{QUERY_STRING} ^route=octemplates/blog/oct_bloglatest$ [NC]
RewriteCond %{REQUEST_URI} ^/index\.php$ [NC]
RewriteRule ^index\.php$ /blog? [R=301,L]


RewriteRule ^sitemap.xml$ index.php?route=extension/feed/google_sitemap [L]
RewriteRule ^filter_sitemap.xml$ index.php?route=extension/feed/ocfilter_sitemap [L]
RewriteRule ^uk_filter_sitemap.xml$ uk/index.php?route=extension/feed/ocfilter_sitemap [L]
RewriteRule ^googlebase.xml$ index.php?route=extension/feed/google_base [L]
RewriteRule ^system/storage/(.*) index.php?route=error/not_found [L]
RewriteRule ^sitemap_index.xml$ index.php?route=extension/hbseo/sitemap [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/product_sitemap_([0-9]+).xml$ index.php?route=extension/hbseo/sitemap/products&hbxmllang=$1&page=$2 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/product_tags_sitemap_([0-9]+).xml$ index.php?route=extension/hbseo/sitemap/product_tags&hbxmllang=$1&page=$2 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/category_sitemap.xml$ index.php?route=extension/hbseo/sitemap/category&hbxmllang=$1 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/brand_sitemap.xml$ index.php?route=extension/hbseo/sitemap/brand&hbxmllang=$1 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/information_sitemap.xml$ index.php?route=extension/hbseo/sitemap/information&hbxmllang=$1 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/category_to_product_sitemap.xml$ index.php?route=extension/hbseo/sitemap/category_to_product&hbxmllang=$1 [L,QSA] 
RewriteRule ^sitemaps/([^?]*)/brand_to_product_sitemap.xml$ index.php?route=extension/hbseo/sitemap/brand_to_product&hbxmllang=$1 [L,QSA] 
RewriteRule ^sitemaps/misc_sitemap.xml$ index.php?route=extension/hbseo/sitemap/misc [L,QSA] 
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !.*\.(ico|gif|jpg|jpeg|png|js|css)
RewriteRule ^([^?]*) index.php?_route_=$1 [L,QSA]

RewriteCond %{REQUEST_URI} ^(.*?)\/{2,}(.*?)$
    RewriteRule . %1/%2 [L,R=301]
    RewriteCond %{THE_REQUEST} //
    RewriteRule .* /$0 [R=301,L]


RewriteCond %{QUERY_STRING} ^route=common/home$
RewriteCond %{REQUEST_METHOD} !^POST$
RewriteRule ^index\.php$ /? [R=301,L]

RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index\.php$ / [R=301,L]


Redirect 301 /sitemap.xml /sitemap_index.xml

