              if ($('[name=\'option['+index+']\']').is(':radio')) {
                {% if (ocdw_in_stock_alert_option_related_disabled) %}
                  $('input[name=\'option['+index+']\'][value='+b['id']+']').attr('disabled', true).removeAttr('selected');
                {% endif %}
                $('input[name=\'option['+index+']\'][value='+b['id']+']').closest('label').after('<button class="btn btn-primary btn-xs {{ ocdw_in_stock_alert_option_button_class ? ocdw_in_stock_alert_option_button_class : '' }}" onclick="ocdw_in_stock_alert_open({a:this,b:\'{{ product_id }}\',c:\'{{ ocdw_in_stock_alert_display_type }}\',d:\''+index+'\',e:\''+b['id']+'\',f:\'2\'})">'+b['text']+'</button>');
              }
              if ($('[name=\'option['+index+'][]\']').is(':checkbox')) {
                {% if (ocdw_in_stock_alert_option_related_disabled) %}
                  $('input[name=\'option['+index+'][]\'][value='+b['id']+']').attr('disabled', true).removeAttr('selected');
                {% endif %}
                $('input[name=\'option['+index+'][]\'][value='+b['id']+']').closest('label').after('<button class="btn btn-primary btn-xs {{ ocdw_in_stock_alert_option_button_class ? ocdw_in_stock_alert_option_button_class : '' }}" onclick="ocdw_in_stock_alert_open({a:this,b:\'{{ product_id }}\',c:\'{{ ocdw_in_stock_alert_display_type }}\',d:\''+index+'\',e:\''+b['id']+'\',f:\'2\'})">'+b['text']+'</button>');
              }
              {% if (ocdw_in_stock_alert_option_related_disabled) %}
                $('select[name=\'option['+index+']\'] option[value='+b['id']+']').attr('disabled', true).removeAttr('selected');
              {% endif %}
              $('select[name=\'option['+index+']\'] option[value='+b['id']+']').parent().after('<button class="btn btn-primary btn-xs {{ ocdw_in_stock_alert_option_button_class ? ocdw_in_stock_alert_option_button_class : '' }}" onclick="ocdw_in_stock_alert_open({a:this,b:\'{{ product_id }}\',c:\'{{ ocdw_in_stock_alert_display_type }}\',d:\''+index+'\',e:\''+b['id']+'\',f:\'2\'})">'+b['text']+'</button>');
