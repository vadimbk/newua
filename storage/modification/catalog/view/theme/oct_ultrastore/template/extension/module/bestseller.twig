{% if products %}
	{% if position == 'column_left' or position == 'column_right' %}
	<div  class="us-module-column-box">
		<div class="panel-heading">{{ heading_title }}</div>

{% if ee_tracking and ee_impression %}
  <script type="text/javascript"><!--
    $(document).ready(function() {
      setIntervalEE(function() {
        var ee_data = JSON.parse('{{ ee_impression_data }}');
        ee_data['url'] = window.location.href;
        ee_data['title'] = document.title;
        $.ajax({
          url: 'index.php?route=extension/module/ee_tracking/listview',
          type: 'post',
          data: ee_data,
          dataType: 'json',
          success: function(json) {
            if (json) {
              console.log(json);
            }
          },
          {% if ee_impression_log %}
          error: function(xhr, exc, error) {
            $.post('index.php?route=extension/module/ee_tracking/listviewlog', { 'error': error + ' (exc: ' + exc + ' status: ' + xhr.statusText + ')', 'url': window.location.href }, function( logs ) {
              console.log(logs);
            });
          }
          {% endif %}
        });
      }, {% if ee_ga_callback %}{{ ee_ga_callback }}{% else %}0{% endif %}, {% if ee_generate_cid %}{{ ee_generate_cid }}{% else %}0{% endif %});
    });
    //--></script>
{% endif %}
            
		<div id="us-column-bestseller{{ module }}" class="d-flex us-module-column-box-content">

			{% if sticker_colors is not empty %}
				<style>
					{% for key, sticker_color in sticker_colors %}
					.us-module-stickers-sticker-{{ key }} {
						color:{{ sticker_color.text_color }};
						background:{{ sticker_color.fon_color }};
					}
					{% endfor %}
				</style>
			{% endif %}
			

    {# Bulk Specials Editor #}
    {{ timer_custom_css_styles is defined ? timer_custom_css_styles : '' }}
    {# Bulk Specials Editor #}
    
			{% for product in products %}
			<div class="us-module-item us-module-column-item us-item{% if not product.can_buy %} us-no-stock{% endif %}">

			{% if product.oct_stickers is not empty%}
			<div class="us-module-stickers">
				{% if oct_sticker_you_save and product.you_save %}
					<div class="us-module-stickers-sticker us-module-stickers-sticker-discount">{{ product.you_save }}</div>
				{% endif %}
				{% for key, oct_sticker in product.oct_stickers %}
					{% if oct_sticker is not empty %}
					<div class="us-module-stickers-sticker us-module-stickers-sticker-{{ key }}">
						{{ oct_sticker }}
					</div>
					{% endif %}
				{% endfor %}
			</div>
			{% endif %}
			
				<ul class="us-module-buttons-list">
					<li class="us-module-buttons-item">
						<a href="javascript:void(0);" class="us-module-buttons-link us-module-buttons-wishlist" title="{{ button_wishlist }}" onclick="wishlist.add('{{ product.product_id }}');"><i class="far fa-heart"></i></a>
					</li>
					<li class="us-module-buttons-item">
						<a href="javascript:void(0);" class="us-module-buttons-link us-module-buttons-compare" title="{{ button_compare }}" onclick="compare.add('{{ product.product_id }}');"><i class="fas fa-sliders-h"></i></a>
					</li>

			{% if oct_popup_view_status %}
			<li class="us-module-buttons-item">
				<a href="javascript:void(0);" class="us-module-buttons-link us-module-buttons-quickview" title="Быстрый просмотр" onclick="octPopUpView('{{ product.product_id }}')"><i class="far fa-eye"></i></a>
			</li>
			{% endif %}
			
				</ul>
			  <div class="us-module-img">
			  	<a href="{{ product.href }}" {% if ee_tracking and ee_click %}onclick="ee_product.click('{{ product.product_id }}', '{{ product.ee_position }}', '{{ ee_type }}')"{% endif %}>
			  		<img src="{{ product.thumb }}" alt="{{ product.name }}" title="{{ product.name }}" class="img-fluid" />
			  	</a>
			  </div>
			  <div class="us-module-title us-module-column-title">
					<a href="{{ product.href }}" {% if ee_tracking and ee_click %}onclick="ee_product.click('{{ product.product_id }}', '{{ product.ee_position }}', '{{ ee_type }}')"{% endif %}>{{ product.name }}</a>
				</div>
				{% if product.rating is not same as(false) %}
			    <div class="us-module-rating d-flex align-items-center justify-content-center">
			        <div class="us-module-rating-stars d-flex align-items-center">
			          {% for i in 1..5 %}
			          {% if product.rating < i %}
			          <span class="us-module-rating-star"></span>
			          {% else %}
			          <span class="us-module-rating-star us-module-rating-star-is"></span>
			          {% endif %}
			          {% endfor %}
			        </div>
					<div class="us-module-reviews">
						<i class="fas fa-comment">
							<span>{{ product.reviews }}</span>
						</i>
					</div>
			    </div>
			    {% endif %}
			    
    {# Bulk Specials Editor #}
    {% if product.timer %}
      
    <div class="timer-block">
      <div class="prices-block">
        <span class="special-price">{{ product.special }}</span>
        <span class="old-price">{{ product.price }}</span>
        <span class="percentage-discount">{{ text_timer_on_products_page ~ '-' ~ product.percentage_discount }}%</span>
      </div>
      <div class="timer_bestseller_{{ product.product_id }}"></div>
    </div>

    <script type="text/javascript">
      $(document).ready(function() {
        $('.timer_bestseller_{{ product.product_id }}').opencartCountdown({
          until: {{ product.special_date_diff }}
        });
      });
    </script>

    {% endif %}
    {# Bulk Specials Editor #}

    {% if product.price and not product.timer
     %}
			    <div class="us-module-price">
			      {% if not product.special %}
			      <span class="us-module-price-actual">{{ product.price }}</span>
			      {% else %}
			      <span class="us-module-price-old">{{ product.price }}</span><span class="us-module-price-new">{{ product.special }}</span>
			      {% endif %}
			      {% if product.tax %}
			      <div class="price-tax">{{ text_tax }} {{ product.tax }}</div>
			      {% endif %}
			    </div>
			    {% endif %}
			    <a href="{% if product.can_buy is not empty %}javascript:void(0);{% else %}{{ product.href }}{% endif %}"{% if product.can_buy is not empty %} {% if ee_tracking and ee_cart %}data-eet-position="{{ product.ee_position }}" data-eet-type="{{ ee_type }}"{% endif %} onclick="cart.add('{{ product.product_id }}');"{% endif %} class="us-module-cart-btn button-cart">{{ (product.stock and not product.can_buy) ? product.stock : button_cart }}</a>
			</div>
			{% endfor %}
		</div>
		<button type="button" id="us-bestseller-button-prev{{ module }}" class="us-column-module-btn us-column-module-prev"><i class="fas fa-chevron-left"></i></button>
		<button type="button" id="us-bestseller-button-next{{ module }}" class="us-column-module-btn us-column-module-next"><i class="fas fa-chevron-right"></i></button>
		<script>
		octShowColumnProducts("us-bestseller-button-prev{{ module }}", "us-bestseller-button-next{{ module }}", "us-column-bestseller{{ module }}");
		</script>
	</div>
	{% else %}
	<div class="row row-padding-top">
		<div class="col-lg-12">
			<div class="us-main-shop-title">{{ heading_title }}</div>

{% if ee_tracking and ee_impression %}
  <script type="text/javascript"><!--
    $(document).ready(function() {
      setIntervalEE(function() {
        var ee_data = JSON.parse('{{ ee_impression_data }}');
