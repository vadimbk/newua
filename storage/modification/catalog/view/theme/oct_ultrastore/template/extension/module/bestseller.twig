		          {% if product.rating < i %}
		          <span class="us-module-rating-star"></span>
		          {% else %}
		          <span class="us-module-rating-star us-module-rating-star-is"></span>
		          {% endif %}
		          {% endfor %}
		        </div>
				<div class="us-module-reviews">
					<i class="fas fa-comment">
						<span>{{ product.reviews }}</span>
					</i>
				</div>
	        </div>
	        	{% endif %}
	        
